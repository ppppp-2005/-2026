.resume-page { min-height: 100vh; padding: 24rpx 24rpx 48rpx; background: #f6f7f2; }
.page-hero { display: flex; align-items: flex-start; justify-content: space-between; padding: 28rpx; color: #fff; background: linear-gradient(135deg, #1f7a4d, #2d8a58 65%, #d78a38); border-radius: 8rpx; }
.hero-copy { flex: 1; min-width: 0; padding-right: 16rpx; }
.hero-label, .hero-badge { padding: 8rpx 14rpx; font-size: 22rpx; border-radius: 8rpx; }
.hero-label { display: inline-flex; background: rgba(22, 64, 43, .34); }
.hero-badge { flex: 0 0 auto; background: rgba(255, 255, 255, .16); border: 1rpx solid rgba(255, 255, 255, .32); }
.hero-title { margin-top: 20rpx; font-size: 44rpx; font-weight: 700; line-height: 1.2; }
.hero-subtitle { margin-top: 12rpx; font-size: 26rpx; line-height: 1.45; }
.feedback-card, .error-card { margin-top: 18rpx; padding: 18rpx 22rpx; font-size: 24rpx; line-height: 1.45; background: #fff7e8; border: 1rpx solid #f3dfb7; border-radius: 8rpx; color: #765c39; }
.form-card, .preview-card { margin-top: 18rpx; padding: 24rpx; background: #fff; border: 1rpx solid #e7ebe3; border-radius: 8rpx; }
.section-title, .preview-name, .error-title { display: block; color: #16251d; font-size: 32rpx; font-weight: 700; line-height: 1.3; }
.field-label { display: block; margin-top: 20rpx; color: #4b5a51; font-size: 25rpx; line-height: 1.35; }
.field-input, .field-textarea { width: 100%; margin-top: 9rpx; padding: 18rpx 20rpx; color: #26342c; font-size: 28rpx; line-height: 1.45; background: #f8faf6; border: 1rpx solid #dfe6dc; border-radius: 8rpx; }
.field-input { min-height: 76rpx; }
.field-textarea { min-height: 150rpx; }
.skill-list { display: flex; flex-wrap: wrap; margin-top: 12rpx; }
.skill-option { display: flex; align-items: center; width: 50%; min-height: 68rpx; color: #3f4c44; font-size: 25rpx; }
.skill-option checkbox { margin-right: 8rpx; }
.error-card { background: #fff1e8; border-color: #efcdb9; color: #8d4d2d; }
.error-title { font-size: 27rpx; color: #8d4d2d; }
.error-item { display: block; margin-top: 8rpx; font-size: 24rpx; }
.primary-button, .secondary-button, .text-button { box-sizing: border-box; display: flex; align-items: center; justify-content: center; width: 100%; min-height: 88rpx; margin-top: 16rpx; padding: 14rpx 24rpx; font-size: 28rpx; font-weight: 600; line-height: 1.4; border-radius: 8rpx; }
.primary-button { color: #fff; background: #1f7a4d; }
.secondary-button { color: #1f7a4d; background: #fff; border: 1rpx solid #1f7a4d; }
.text-button { color: #6f7972; font-size: 24rpx; background: transparent; }
.primary-button::after, .secondary-button::after, .text-button::after { border: 0; }
.preview-head { display: flex; justify-content: space-between; align-items: flex-start; }
.preview-head > view { display: flex; flex-direction: column; flex: 1; min-width: 0; }
.preview-name { font-size: 38rpx; }
.preview-badge { flex: 0 0 auto; padding: 7rpx 12rpx; color: #a45f3d; font-size: 22rpx; background: #fff1e8; border-radius: 8rpx; }
.preview-meta, .preview-line, .preview-body, .preview-warning { display: block; margin-top: 9rpx; color: #6f7972; font-size: 25rpx; line-height: 1.5; }
.preview-section { margin-top: 24rpx; padding-top: 22rpx; border-top: 1rpx solid #edf1eb; }
.preview-line { color: #3f4c44; }
.preview-salary { display: block; margin-top: 8rpx; color: #e46d1a; font-size: 29rpx; font-weight: 700; }
.tag-row { display: flex; flex-wrap: wrap; margin-top: 12rpx; }
.skill-tag { margin: 0 10rpx 10rpx 0; padding: 8rpx 12rpx; color: #1f7a4d; font-size: 23rpx; background: #e8f4ed; border-radius: 8rpx; }
.strong { font-weight: 700; color: #26342c; }
.preview-warning { padding: 16rpx; color: #765c39; background: #fff7e8; border-radius: 8rpx; }
@media (max-width: 340px) { .skill-option { width: 100%; } }
