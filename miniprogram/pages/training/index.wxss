.training-page {
  min-height: 100vh;
  padding: 24rpx 24rpx 48rpx;
  background: #f6f7f2;
}

.training-hero {
  display: flex;
  align-items: stretch;
  justify-content: space-between;
  overflow: hidden;
  padding: 28rpx;
  color: #ffffff;
  background: linear-gradient(135deg, #1f7a4d 0%, #2d8a58 62%, #d78a38 100%);
  border-radius: 8rpx;
}

.hero-copy {
  min-width: 0;
  padding-right: 18rpx;
}

.hero-label {
  display: inline-flex;
  padding: 8rpx 16rpx;
  color: #fff7df;
  font-size: 24rpx;
  line-height: 1.2;
  background: rgba(22, 64, 43, 0.34);
  border-radius: 8rpx;
}

.hero-title {
  margin-top: 22rpx;
  font-size: 46rpx;
  font-weight: 700;
  line-height: 1.18;
}

.hero-subtitle {
  margin-top: 12rpx;
  color: rgba(255, 255, 255, 0.92);
  font-size: 26rpx;
  line-height: 1.45;
}

.hero-count {
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 0 0 auto;
  flex-direction: column;
  width: 148rpx;
  min-height: 148rpx;
  margin-top: 6rpx;
  background: rgba(255, 255, 255, 0.16);
  border: 1rpx solid rgba(255, 255, 255, 0.32);
  border-radius: 8rpx;
}

.hero-count-number {
  font-size: 46rpx;
  font-weight: 700;
  line-height: 1;
}

.hero-count-label {
  margin-top: 10rpx;
  color: rgba(255, 255, 255, 0.86);
  font-size: 22rpx;
  line-height: 1.2;
}

.category-section {
  margin-top: 24rpx;
  padding: 24rpx;
  background: #ffffff;
  border: 1rpx solid #e7ebe3;
  border-radius: 8rpx;
}

.section-head,
.course-heading {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
}

.section-title {
  display: block;
  color: #16251d;
  font-size: 34rpx;
  font-weight: 700;
  line-height: 1.25;
}

.section-subtitle {
  display: block;
  margin-top: 8rpx;
  color: #778178;
  font-size: 23rpx;
  line-height: 1.4;
}

.section-status {
  flex: 0 0 auto;
  margin-left: 18rpx;
  color: #1f7a4d;
  font-size: 24rpx;
  line-height: 1.4;
}

.category-scroll {
  width: 100%;
  margin-top: 20rpx;
  white-space: nowrap;
}

.category-row {
  display: inline-flex;
  min-width: 100%;
}

.category-chip {
  flex: 0 0 auto;
  margin-right: 12rpx;
  padding: 15rpx 24rpx;
  color: #3f4a44;
  font-size: 26rpx;
  line-height: 1.2;
  background: #f8faf6;
  border: 1rpx solid #dde5dc;
  border-radius: 8rpx;
}

.category-chip-active {
  color: #ffffff;
  font-weight: 600;
  background: #1f7a4d;
  border-color: #1f7a4d;
}

.notice-card {
  display: flex;
  align-items: flex-start;
  margin-top: 18rpx;
  padding: 20rpx 22rpx;
  background: #fff7e8;
  border: 1rpx solid #f3dfb7;
  border-radius: 8rpx;
}

.notice-title {
  flex: 0 0 auto;
  color: #9a5a16;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 1.45;
}

.notice-text {
  flex: 1;
  min-width: 0;
  margin-left: 14rpx;
  color: #7a5c34;
  font-size: 24rpx;
  line-height: 1.45;
}

.course-heading {
  margin-top: 28rpx;
  margin-bottom: 16rpx;
}

.course-list {
  display: flex;
  flex-direction: column;
}

.course-card {
  margin-bottom: 18rpx;
  padding: 24rpx;
  background: #ffffff;
  border: 1rpx solid #e7ebe3;
  border-radius: 8rpx;
  box-shadow: 0 10rpx 24rpx rgba(31, 41, 51, 0.04);
}

.course-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
}

.course-title-wrap {
  display: flex;
  align-items: center;
  flex: 1;
  min-width: 0;
  padding-right: 18rpx;
}

.course-title {
  color: #16251d;
  font-size: 32rpx;
  font-weight: 700;
  line-height: 1.35;
}

.course-badge {
  flex: 0 0 auto;
  margin-left: 12rpx;
  padding: 5rpx 10rpx;
  color: #a45f3d;
  font-size: 21rpx;
  line-height: 1.2;
  background: #fff1e8;
  border-radius: 8rpx;
}

.course-fee {
  display: flex;
  align-items: flex-end;
  flex: 0 0 auto;
  flex-direction: column;
  max-width: 210rpx;
  text-align: right;
}

.course-fee-label {
  color: #8a6a4e;
  font-size: 20rpx;
  font-weight: 500;
  line-height: 1.2;
}

.course-fee-value {
  margin-top: 5rpx;
  color: #d86619;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 1.4;
}

.course-summary {
  display: block;
  margin-top: 14rpx;
  color: #4b5a51;
  font-size: 26rpx;
  line-height: 1.5;
}

.info-list {
  margin-top: 18rpx;
  padding: 16rpx 18rpx;
  background: #f8faf6;
  border: 1rpx solid #e8ede5;
  border-radius: 8rpx;
}

.info-row {
  display: flex;
  align-items: flex-start;
  padding: 10rpx 0;
}

.info-label {
  flex: 0 0 auto;
  width: 72rpx;
  color: #1f7a4d;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 1.45;
}

.info-value-wrap {
  display: flex;
  flex: 1;
  flex-direction: column;
  min-width: 0;
}

.info-value {
  flex: 1;
  min-width: 0;
  color: #334139;
  font-size: 25rpx;
  line-height: 1.45;
}

.info-note {
  margin-top: 4rpx;
  color: #7b867f;
  font-size: 22rpx;
  line-height: 1.35;
}

.tag-row {
  display: flex;
  flex-wrap: wrap;
  margin-top: 16rpx;
}

.course-tag {
  margin-right: 10rpx;
  margin-bottom: 10rpx;
  padding: 8rpx 12rpx;
  color: #1f7a4d;
  font-size: 22rpx;
  line-height: 1.2;
  background: #e8f4ed;
  border-radius: 8rpx;
}

.course-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 8rpx;
  padding-top: 18rpx;
  border-top: 1rpx solid #eef2ed;
}

.provider-name {
  flex: 1;
  min-width: 0;
  padding-right: 18rpx;
  color: #7a837d;
  font-size: 22rpx;
  line-height: 1.4;
}

.detail-button {
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 0 0 auto;
  min-width: 154rpx;
  min-height: 88rpx;
  margin: 0;
  padding: 12rpx 20rpx;
  box-sizing: border-box;
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 600;
  line-height: 1.3;
  background: #1f7a4d;
  border-radius: 8rpx;
}

.detail-button::after {
  border: 0;
}

.detail-button:active {
  opacity: 0.82;
}
