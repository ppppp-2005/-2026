.return-page {
  min-height: 100vh;
  padding: 24rpx 24rpx 48rpx;
  background: #f6f7f2;
}

.return-hero {
  padding: 30rpx 28rpx;
  color: #ffffff;
  background: linear-gradient(135deg, #1f7a4d 0%, #2d8a58 62%, #c98238 100%);
  border-radius: 8rpx;
}

.hero-label {
  display: inline-flex;
  padding: 8rpx 16rpx;
  color: #fff7df;
  font-size: 24rpx;
  line-height: 1.2;
  background: rgba(22, 64, 43, 0.36);
  border-radius: 8rpx;
}

.hero-title {
  max-width: 580rpx;
  margin-top: 22rpx;
  font-size: 48rpx;
  font-weight: 700;
  line-height: 1.2;
}

.hero-subtitle {
  margin-top: 14rpx;
  color: rgba(255, 255, 255, 0.94);
  font-size: 28rpx;
  line-height: 1.5;
}

.hero-notice {
  margin-top: 24rpx;
  padding: 16rpx 18rpx;
  color: #fff8e9;
  font-size: 23rpx;
  line-height: 1.45;
  background: rgba(22, 64, 43, 0.28);
  border: 1rpx solid rgba(255, 255, 255, 0.26);
  border-radius: 8rpx;
}

.category-panel {
  margin-top: 20rpx;
  padding: 24rpx 18rpx 18rpx;
  background: #ffffff;
  border: 1rpx solid #e7ebe3;
  border-radius: 8rpx;
}

.category-heading {
  padding: 0 6rpx;
  color: #16251d;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1.3;
}

.category-grid {
  display: flex;
  margin: 16rpx -6rpx 0;
}

.category-card {
  display: flex;
  align-items: flex-start;
  justify-content: flex-start;
  flex-direction: column;
  width: calc(33.333% - 12rpx);
  min-height: 176rpx;
  margin: 6rpx;
  padding: 18rpx 14rpx;
  color: #26342d;
  line-height: 1.2;
  text-align: left;
  background: #f8faf6;
  border: 1rpx solid #e2e8df;
  border-radius: 8rpx;
}

.category-card::after,
.filter-chip::after,
.primary-action::after,
.secondary-action::after {
  border: 0;
}

.category-card-active {
  background: #e8f4ed;
  border-color: #1f7a4d;
}

.category-name {
  color: #16251d;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 1.3;
}

.category-summary {
  margin-top: 10rpx;
  color: #59665e;
  font-size: 22rpx;
  line-height: 1.35;
}

.category-count {
  margin-top: auto;
  padding-top: 12rpx;
  color: #1f7a4d;
  font-size: 21rpx;
  line-height: 1.3;
}

.content-section {
  margin-top: 22rpx;
  padding: 26rpx 22rpx;
  background: #ffffff;
  border: 1rpx solid #e7ebe3;
  border-radius: 8rpx;
}

.section-head {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
}

.section-kicker {
  display: inline-flex;
  padding: 6rpx 12rpx;
  color: #1f7a4d;
  font-size: 22rpx;
  font-weight: 700;
  line-height: 1.2;
  background: #e8f4ed;
  border-radius: 8rpx;
}

.section-kicker-warm {
  color: #955518;
  background: #fff1df;
}

.section-kicker-blue {
  color: #2f6296;
  background: #eaf2f8;
}

.section-title {
  display: block;
  margin-top: 12rpx;
  color: #16251d;
  font-size: 36rpx;
  font-weight: 700;
  line-height: 1.25;
}

.section-subtitle {
  display: block;
  margin-top: 8rpx;
  color: #707b74;
  font-size: 24rpx;
  line-height: 1.4;
}

.section-count {
  flex: 0 0 auto;
  padding: 7rpx 12rpx;
  color: #1f7a4d;
  font-size: 23rpx;
  line-height: 1.2;
  background: #f0f7f2;
  border-radius: 8rpx;
}

.filter-scroll {
  width: 100%;
  margin-top: 20rpx;
  white-space: nowrap;
}

.filter-row {
  display: inline-flex;
  min-width: 100%;
}

.filter-chip {
  flex: 0 0 auto;
  min-width: 96rpx;
  height: auto;
  margin: 0 12rpx 0 0;
  padding: 13rpx 22rpx;
  color: #3f4a44;
  font-size: 25rpx;
  line-height: 1.2;
  background: #f8faf6;
  border: 1rpx solid #dde5dc;
  border-radius: 999rpx;
}

.filter-chip-active {
  color: #ffffff;
  background: #1f7a4d;
  border-color: #1f7a4d;
}

.job-list,
.support-list,
.service-list {
  display: flex;
  flex-direction: column;
  margin-top: 18rpx;
}

.job-card,
.support-card,
.service-card {
  margin-top: 16rpx;
  padding: 22rpx;
  background: #fbfcf9;
  border: 1rpx solid #e4e9e1;
  border-radius: 8rpx;
}

.job-card:first-child,
.support-card:first-child,
.service-card:first-child {
  margin-top: 0;
}

.job-card-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
}

.job-title-wrap {
  display: flex;
  align-items: center;
  flex: 1;
  min-width: 0;
  padding-right: 14rpx;
}

.job-title {
  color: #16251d;
  font-size: 32rpx;
  font-weight: 700;
  line-height: 1.35;
}

.job-type {
  flex: 0 0 auto;
  margin-left: 10rpx;
  padding: 5rpx 9rpx;
  color: #1f7a4d;
  font-size: 20rpx;
  line-height: 1.2;
  background: #e8f4ed;
  border-radius: 8rpx;
}

.job-salary {
  flex: 0 0 auto;
  color: #d86719;
  font-size: 29rpx;
  font-weight: 700;
  line-height: 1.4;
}

.job-place {
  margin-top: 14rpx;
  color: #35443b;
  font-size: 26rpx;
  font-weight: 600;
  line-height: 1.4;
}

.job-company,
.job-summary {
  margin-top: 8rpx;
  color: #6c7770;
  font-size: 24rpx;
  line-height: 1.45;
}

.tag-row {
  display: flex;
  flex-wrap: wrap;
  margin-top: 16rpx;
}

.info-tag {
  margin-right: 10rpx;
  margin-bottom: 10rpx;
  padding: 7rpx 11rpx;
  color: #1f7a4d;
  font-size: 22rpx;
  line-height: 1.2;
  background: #edf6f0;
  border-radius: 8rpx;
}

.card-action-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 8rpx;
  padding-top: 18rpx;
  border-top: 1rpx solid #e8ece6;
}

.action-note {
  display: flex;
  flex: 1;
  flex-direction: column;
  min-width: 0;
  padding-right: 18rpx;
}

.action-note-label {
  color: #87918a;
  font-size: 21rpx;
  line-height: 1.3;
}

.action-note-text {
  margin-top: 4rpx;
  color: #46534b;
  font-size: 23rpx;
  line-height: 1.35;
}

.primary-action,
.secondary-action {
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 0 0 auto;
  width: auto;
  height: auto;
  margin: 0;
  padding: 15rpx 22rpx;
  color: #ffffff;
  font-size: 25rpx;
  font-weight: 600;
  line-height: 1.2;
  background: #1f7a4d;
  border: 0;
  border-radius: 8rpx;
}

.primary-action:active,
.secondary-action:active,
.category-card:active,
.filter-chip:active {
  opacity: 0.82;
}

.plain-tip {
  display: flex;
  align-items: flex-start;
  margin-top: 18rpx;
  padding: 18rpx;
  background: #fff7e8;
  border: 1rpx solid #f3dfb7;
  border-radius: 8rpx;
}

.plain-tip-title {
  flex: 0 0 auto;
  color: #915414;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 1.45;
}

.plain-tip-text {
  flex: 1;
  min-width: 0;
  margin-left: 14rpx;
  color: #725a3a;
  font-size: 23rpx;
  line-height: 1.45;
}

.support-title,
.service-title {
  color: #16251d;
  font-size: 31rpx;
  font-weight: 700;
  line-height: 1.35;
}

.detail-line {
  display: flex;
  align-items: flex-start;
  margin-top: 14rpx;
}

.detail-label {
  flex: 0 0 auto;
  width: 112rpx;
  color: #7b847e;
  font-size: 23rpx;
  font-weight: 600;
  line-height: 1.5;
}

.detail-text {
  flex: 1;
  min-width: 0;
  color: #3e4b43;
  font-size: 25rpx;
  line-height: 1.5;
}

.reminder-box {
  margin-top: 16rpx;
  padding: 14rpx 16rpx;
  color: #76562f;
  font-size: 23rpx;
  line-height: 1.45;
  background: #fff6e9;
  border-radius: 8rpx;
}

.secondary-action {
  margin-top: 18rpx;
  color: #1f7a4d;
  background: #e8f4ed;
  border: 1rpx solid #bcd8c7;
}

.service-purpose {
  display: block;
  margin-top: 9rpx;
  color: #59665e;
  font-size: 25rpx;
  line-height: 1.45;
}

.service-info {
  margin-top: 17rpx;
  border-top: 1rpx solid #e7ece6;
}

.service-info-row {
  display: flex;
  align-items: flex-start;
  padding: 14rpx 0;
  border-bottom: 1rpx solid #edf0eb;
}

.service-info-label {
  flex: 0 0 auto;
  width: 106rpx;
  color: #2f6296;
  font-size: 23rpx;
  font-weight: 700;
  line-height: 1.45;
}

.service-info-text {
  flex: 1;
  min-width: 0;
  color: #3e4b43;
  font-size: 24rpx;
  line-height: 1.45;
}

.service-action {
  color: #2f6296;
  background: #eaf2f8;
  border-color: #bfd2e2;
}

.data-note {
  margin-top: 22rpx;
  padding: 22rpx;
  color: #68736c;
  background: #eef1eb;
  border-radius: 8rpx;
}

.data-note-title {
  display: block;
  color: #46534b;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 1.35;
}

.data-note-text {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  line-height: 1.5;
}
