.applications-page { min-height: 100vh; padding: 24rpx 24rpx 48rpx; background: #f6f7f2; }
.page-hero { display: flex; align-items: flex-start; justify-content: space-between; padding: 28rpx; color: #fff; background: linear-gradient(135deg, #1f7a4d, #2d8a58 65%, #d78a38); border-radius: 8rpx; }
.hero-copy { flex: 1; min-width: 0; padding-right: 16rpx; }
.hero-label, .hero-badge { padding: 8rpx 14rpx; font-size: 22rpx; border-radius: 8rpx; }
.hero-label { display: inline-flex; background: rgba(22, 64, 43, .34); }
.hero-badge { flex: 0 0 auto; background: rgba(255, 255, 255, .16); border: 1rpx solid rgba(255, 255, 255, .32); }
.hero-title { margin-top: 20rpx; font-size: 44rpx; font-weight: 700; line-height: 1.2; }
.hero-subtitle { margin-top: 12rpx; font-size: 26rpx; line-height: 1.45; }
.feedback-card { margin-top: 18rpx; padding: 18rpx 22rpx; color: #765c39; font-size: 24rpx; line-height: 1.45; background: #fff7e8; border: 1rpx solid #f3dfb7; border-radius: 8rpx; }
.filter-scroll { width: 100%; margin-top: 18rpx; white-space: nowrap; }
.filter-row { display: inline-flex; min-width: 100%; }
.filter-chip { flex: 0 0 auto; margin-right: 12rpx; padding: 14rpx 22rpx; color: #3f4a44; font-size: 26rpx; background: #fff; border: 1rpx solid #dde5dc; border-radius: 999rpx; }
.filter-chip-active { color: #fff; background: #1f7a4d; border-color: #1f7a4d; }
.record-count { margin: 24rpx 0 14rpx; color: #667169; font-size: 24rpx; }
.record-card, .empty-card { margin-bottom: 16rpx; padding: 24rpx; background: #fff; border: 1rpx solid #e7ebe3; border-radius: 8rpx; box-shadow: 0 10rpx 24rpx rgba(31, 41, 51, .04); }
.record-top { display: flex; align-items: flex-start; justify-content: space-between; }
.record-title-copy { display: flex; flex: 1; min-width: 0; flex-direction: column; padding-right: 14rpx; }
.job-title { color: #16251d; font-size: 32rpx; font-weight: 700; line-height: 1.35; }
.company-name { margin-top: 7rpx; color: #5f6c64; font-size: 24rpx; line-height: 1.4; }
.status-badge { flex: 0 0 auto; padding: 7rpx 11rpx; font-size: 22rpx; border-radius: 8rpx; }
.status-pending { color: #9a5a16; background: #fff1d8; }
.status-viewed { color: #1f6a78; background: #e5f4f6; }
.status-contacted { color: #1f7a4d; background: #e8f4ed; }
.status-closed { color: #6b7280; background: #eef0ed; }
.salary { display: block; margin-top: 16rpx; color: #e46d1a; font-size: 29rpx; font-weight: 700; }
.record-meta { display: flex; flex-wrap: wrap; justify-content: space-between; gap: 10rpx; margin-top: 12rpx; color: #778178; font-size: 23rpx; line-height: 1.4; }
.update-box { display: flex; align-items: flex-start; margin-top: 18rpx; padding: 16rpx; background: #f8faf6; border-radius: 8rpx; }
.update-label { flex: 0 0 auto; color: #1f7a4d; font-size: 23rpx; font-weight: 700; }
.update-text { flex: 1; min-width: 0; margin-left: 14rpx; color: #536057; font-size: 23rpx; line-height: 1.45; }
.record-detail { margin-top: 18rpx; padding-top: 18rpx; border-top: 1rpx solid #edf1eb; }
.detail-title { display: block; color: #16251d; font-size: 27rpx; font-weight: 700; }
.detail-text { display: block; margin-top: 8rpx; color: #667169; font-size: 24rpx; line-height: 1.5; }
.contact-button { box-sizing: border-box; display: flex; align-items: center; justify-content: center; width: 100%; min-height: 88rpx; margin-top: 16rpx; padding: 14rpx 20rpx; color: #1f7a4d; font-size: 25rpx; font-weight: 600; line-height: 1.4; background: #fff; border: 1rpx solid #1f7a4d; border-radius: 8rpx; }
.contact-button::after { border: 0; }
.expand-text { display: block; margin-top: 16rpx; color: #1f7a4d; font-size: 24rpx; text-align: right; }
.empty-card { color: #667169; font-size: 26rpx; text-align: center; }
