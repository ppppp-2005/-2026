.profile-page {
  min-height: 100vh;
  padding: 24rpx 24rpx 48rpx;
  background: #f6f7f2;
}

.profile-hero {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  min-height: 236rpx;
  padding: 28rpx;
  color: #ffffff;
  background: linear-gradient(135deg, #1f7a4d 0%, #2d8a58 62%, #d78a38 100%);
  border-radius: 8rpx;
}

.hero-copy {
  flex: 1;
  min-width: 0;
  padding-right: 18rpx;
}

.hero-label,
.hero-data-label {
  display: inline-flex;
  padding: 8rpx 14rpx;
  font-size: 22rpx;
  line-height: 1.2;
  border-radius: 8rpx;
}

.hero-label {
  color: #fff7df;
  background: rgba(22, 64, 43, 0.34);
}

.hero-data-label {
  flex: 0 0 auto;
  color: #ffffff;
  background: rgba(255, 255, 255, 0.16);
  border: 1rpx solid rgba(255, 255, 255, 0.32);
}

.hero-title {
  margin-top: 20rpx;
  font-size: 46rpx;
  font-weight: 700;
  line-height: 1.18;
}

.hero-subtitle {
  margin-top: 12rpx;
  color: rgba(255, 255, 255, 0.92);
  font-size: 26rpx;
  line-height: 1.45;
}

.identity-card,
.progress-card,
.intent-card,
.entry-card,
.role-card,
.help-card {
  background: #ffffff;
  border: 1rpx solid #e7ebe3;
  border-radius: 8rpx;
  box-shadow: 0 10rpx 24rpx rgba(31, 41, 51, 0.04);
}

.identity-card,
.progress-card,
.intent-card,
.help-card {
  margin-top: 18rpx;
  padding: 24rpx;
}

.identity-card {
  margin-top: 24rpx;
}

.identity-top {
  display: flex;
  align-items: center;
}

.identity-copy {
  display: flex;
  flex: 1;
  flex-direction: column;
  min-width: 0;
}

.identity-name,
.card-title,
.section-title,
.entry-title,
.role-name {
  color: #16251d;
  font-weight: 700;
}

.identity-name {
  font-size: 34rpx;
  line-height: 1.3;
}

.identity-status {
  margin-top: 7rpx;
  color: #1f7a4d;
  font-size: 24rpx;
  line-height: 1.35;
}

.identity-status-expired {
  color: #b54a3d;
}

.identity-note,
.card-note,
.button-note,
.help-text {
  display: block;
  color: #6f7972;
  font-size: 24rpx;
  line-height: 1.5;
}

.identity-note {
  margin-top: 18rpx;
}

.login-button {
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  min-height: 88rpx;
  margin-top: 20rpx;
  padding: 14rpx 24rpx;
  color: #ffffff;
  font-size: 29rpx;
  font-weight: 600;
  line-height: 1.35;
  background: #1f7a4d;
  border-radius: 8rpx;
}

.login-button::after {
  border: 0;
}

.button-note {
  margin-top: 12rpx;
  text-align: center;
}

.notice-card {
  margin-top: 18rpx;
  padding: 18rpx 22rpx;
  color: #7a5c34;
  font-size: 24rpx;
  line-height: 1.45;
  background: #fff7e8;
  border: 1rpx solid #f3dfb7;
  border-radius: 8rpx;
}

.card-heading-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.card-title,
.section-title {
  font-size: 32rpx;
  line-height: 1.3;
}

.progress-value {
  color: #1f7a4d;
  font-size: 34rpx;
  font-weight: 700;
}

.progress-track {
  overflow: hidden;
  height: 18rpx;
  margin-top: 18rpx;
  background: #e9eee9;
  border-radius: 8rpx;
}

.progress-fill {
  height: 100%;
  background: #1f7a4d;
}

.card-note {
  margin-top: 14rpx;
}

.demo-tag {
  flex: 0 0 auto;
  padding: 6rpx 10rpx;
  color: #a45f3d;
  font-size: 21rpx;
  background: #fff1e8;
  border-radius: 8rpx;
}

.intent-line {
  display: flex;
  align-items: flex-start;
  margin-top: 16rpx;
  font-size: 26rpx;
  line-height: 1.45;
}

.intent-label {
  flex: 0 0 auto;
  width: 92rpx;
  color: #7a837d;
}

.intent-value {
  flex: 1;
  min-width: 0;
  color: #3f4c44;
}

.salary-text {
  color: #e46d1a;
  font-weight: 700;
}

.summary-grid {
  display: flex;
  margin-top: 18rpx;
  padding: 22rpx 8rpx;
  background: #e8f4ed;
  border: 1rpx solid #d8e9dd;
  border-radius: 8rpx;
}

.summary-item {
  display: flex;
  align-items: center;
  flex: 1;
  flex-direction: column;
  min-width: 0;
  border-left: 1rpx solid #cadfce;
}

.summary-item:first-child {
  border-left: 0;
}

.summary-value {
  color: #1f7a4d;
  font-size: 40rpx;
  font-weight: 700;
  line-height: 1;
}

.summary-label {
  margin-top: 9rpx;
  color: #536057;
  font-size: 22rpx;
  line-height: 1.3;
  text-align: center;
}

.section-head {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  margin-top: 30rpx;
  margin-bottom: 14rpx;
}

.section-note {
  padding-left: 16rpx;
  color: #778178;
  font-size: 22rpx;
  line-height: 1.35;
  text-align: right;
}

.entry-card {
  display: flex;
  align-items: center;
  min-height: 120rpx;
  margin-bottom: 14rpx;
  padding: 20rpx;
}

.entry-mark {
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 0 0 auto;
  width: 58rpx;
  height: 58rpx;
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 700;
  background: #1f7a4d;
  border-radius: 8rpx;
}

.entry-copy {
  display: flex;
  flex: 1;
  flex-direction: column;
  min-width: 0;
  margin-left: 18rpx;
}

.entry-title,
.role-name {
  font-size: 29rpx;
  line-height: 1.3;
}

.entry-description,
.role-description {
  margin-top: 7rpx;
  color: #737d76;
  font-size: 23rpx;
  line-height: 1.4;
}

.entry-action {
  flex: 0 0 auto;
  margin-left: 12rpx;
  color: #1f7a4d;
  font-size: 24rpx;
}

.role-list {
  display: flex;
  flex-wrap: wrap;
  margin: -7rpx;
}

.role-card {
  display: flex;
  width: calc(50% - 14rpx);
  min-height: 126rpx;
  margin: 7rpx;
  padding: 20rpx;
  flex-direction: column;
}

.role-card-active {
  background: #e8f4ed;
  border-color: #1f7a4d;
}

.role-card-disabled {
  background: #f3f4f1;
}

.role-card-disabled .role-name,
.role-card-disabled .role-description {
  color: #8a928c;
}

.help-toggle {
  color: #1f7a4d;
  font-size: 24rpx;
}

.help-text {
  margin-top: 14rpx;
}

@media (max-width: 340px) {
  .profile-page {
    padding-right: 18rpx;
    padding-left: 18rpx;
  }

  .role-card {
    width: calc(100% - 14rpx);
  }

  .entry-action {
    font-size: 22rpx;
  }
}
