.messages-page {
  min-height: 100vh;
  padding: 24rpx 24rpx 48rpx;
  background: #f6f7f2;
}

.page-hero {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  min-height: 230rpx;
  padding: 28rpx;
  color: #ffffff;
  background: linear-gradient(135deg, #1f7a4d 0%, #2d8a58 64%, #d78a38 100%);
  border-radius: 8rpx;
}

.hero-copy {
  flex: 1;
  min-width: 0;
  padding-right: 18rpx;
}

.hero-label {
  display: inline-flex;
  padding: 8rpx 14rpx;
  color: #fff7df;
  font-size: 22rpx;
  line-height: 1.2;
  background: rgba(22, 64, 43, 0.34);
  border-radius: 8rpx;
}

.hero-title {
  margin-top: 20rpx;
  font-size: 46rpx;
  font-weight: 700;
  line-height: 1.18;
}

.hero-subtitle {
  margin-top: 12rpx;
  color: rgba(255, 255, 255, 0.92);
  font-size: 26rpx;
  line-height: 1.45;
}

.unread-summary {
  display: flex;
  align-items: center;
  flex: 0 0 auto;
  min-width: 108rpx;
  padding: 16rpx 12rpx;
  flex-direction: column;
  background: rgba(255, 255, 255, 0.16);
  border: 1rpx solid rgba(255, 255, 255, 0.32);
  border-radius: 8rpx;
}

.unread-value {
  font-size: 42rpx;
  font-weight: 700;
  line-height: 1;
}

.unread-label {
  margin-top: 8rpx;
  font-size: 21rpx;
  line-height: 1.2;
}

.feedback-card {
  margin-top: 18rpx;
  padding: 18rpx 22rpx;
  color: #765c39;
  font-size: 24rpx;
  line-height: 1.45;
  background: #fff7e8;
  border: 1rpx solid #f3dfb7;
  border-radius: 8rpx;
}

.scenario-card,
.state-card,
.pagination-card {
  margin-top: 18rpx;
  padding: 22rpx;
  background: #ffffff;
  border: 1rpx solid #e2e8df;
  border-radius: 8rpx;
}

.scenario-title,
.state-title {
  color: #16251d;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 1.4;
}

.scenario-scroll {
  width: 100%;
  margin-top: 12rpx;
  white-space: nowrap;
}

.scenario-row {
  display: inline-flex;
}

.scenario-chip {
  box-sizing: border-box;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 88rpx;
  margin-right: 12rpx;
  padding: 14rpx 20rpx;
  color: #536057;
  font-size: 24rpx;
  background: #f7f9f5;
  border: 1rpx solid #dce5db;
  border-radius: 8rpx;
}

.scenario-chip-active {
  color: #ffffff;
  background: #1f7a4d;
  border-color: #1f7a4d;
}

.state-card {
  padding: 32rpx 24rpx;
  text-align: center;
}

.state-card-error {
  border-color: #edd2bc;
}

.state-kicker {
  color: #a45f3d;
  font-size: 21rpx;
  line-height: 1.3;
  text-transform: uppercase;
}

.state-text,
.state-note,
.page-error-text,
.page-end {
  color: #667169;
  font-size: 24rpx;
  line-height: 1.5;
}

.state-text {
  margin-top: 10rpx;
}

.state-note {
  margin-top: 12rpx;
  font-size: 22rpx;
}

.state-button,
.load-more-button {
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  min-height: 88rpx;
  margin-top: 18rpx;
  padding: 14rpx 24rpx;
  color: #ffffff;
  font-size: 26rpx;
  line-height: 1.4;
  background: #1f7a4d;
  border-radius: 8rpx;
}

.state-button::after,
.load-more-button::after {
  border: 0;
}

.category-scroll {
  width: 100%;
  margin-top: 18rpx;
  white-space: nowrap;
}

.category-row {
  display: inline-flex;
  min-width: 100%;
}

.category-chip {
  box-sizing: border-box;
  display: flex;
  align-items: flex-start;
  flex: 0 0 auto;
  justify-content: center;
  min-height: 88rpx;
  margin-right: 12rpx;
  padding: 13rpx 20rpx;
  color: #3f4a44;
  font-size: 26rpx;
  line-height: 1.3;
  flex-direction: column;
  background: #ffffff;
  border: 1rpx solid #dde5dc;
  border-radius: 8rpx;
}

.category-chip-active {
  color: #ffffff;
  background: #1f7a4d;
  border-color: #1f7a4d;
}

.category-unread {
  margin-top: 4rpx;
  color: #a45f3d;
  font-size: 20rpx;
}

.category-chip-active .category-unread {
  color: #fff1d8;
}

.tool-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin: 22rpx 0 14rpx;
}

.unread-toggle,
.mark-all {
  box-sizing: border-box;
  display: flex;
  align-items: center;
  min-height: 88rpx;
  font-size: 24rpx;
  line-height: 1.3;
}

.unread-toggle {
  padding: 11rpx 16rpx;
  color: #536057;
  background: #ffffff;
  border: 1rpx solid #dce5db;
  border-radius: 8rpx;
}

.unread-toggle-active {
  color: #ffffff;
  background: #1f7a4d;
  border-color: #1f7a4d;
}

.mark-all {
  justify-content: flex-end;
  padding: 12rpx 0 12rpx 18rpx;
  color: #1f7a4d;
  text-align: right;
}

.message-card,
.empty-card {
  margin-bottom: 16rpx;
  padding: 24rpx;
  background: #ffffff;
  border: 1rpx solid #e7ebe3;
  border-radius: 8rpx;
  box-shadow: 0 10rpx 24rpx rgba(31, 41, 51, 0.04);
}

.message-card-unread {
  border-left: 6rpx solid #1f7a4d;
}

.message-top,
.message-title-row,
.message-bottom {
  display: flex;
  align-items: center;
}

.message-top,
.message-bottom {
  justify-content: space-between;
}

.category-label {
  padding: 6rpx 10rpx;
  color: #1f7a4d;
  font-size: 22rpx;
  line-height: 1.2;
  background: #e8f4ed;
  border-radius: 8rpx;
}

.message-time {
  margin-left: 16rpx;
  color: #7a837d;
  font-size: 22rpx;
}

.message-title-row {
  align-items: flex-start;
  margin-top: 16rpx;
}

.unread-dot {
  flex: 0 0 auto;
  width: 14rpx;
  height: 14rpx;
  margin-top: 13rpx;
  margin-right: 12rpx;
  background: #d9782d;
  border-radius: 50%;
}

.message-title {
  flex: 1;
  min-width: 0;
  color: #16251d;
  font-size: 31rpx;
  font-weight: 700;
  line-height: 1.35;
}

.message-preview {
  display: block;
  margin-top: 10rpx;
  color: #667169;
  font-size: 25rpx;
  line-height: 1.5;
}

.message-bottom {
  align-items: flex-end;
  margin-top: 18rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #edf1eb;
}

.message-job {
  flex: 1;
  min-width: 0;
  padding-right: 12rpx;
  color: #778178;
  font-size: 22rpx;
  line-height: 1.4;
}

.read-action,
.detail-action {
  flex: 0 0 auto;
  color: #1f7a4d;
  font-size: 23rpx;
  line-height: 1.4;
}

.read-action {
  display: inline-flex;
  align-items: center;
  min-height: 88rpx;
  padding-left: 18rpx;
}

.empty-card {
  padding: 46rpx 28rpx;
  text-align: center;
}

.empty-title {
  color: #16251d;
  font-size: 30rpx;
  font-weight: 700;
}

.empty-text {
  margin-top: 12rpx;
  color: #6f7972;
  font-size: 24rpx;
  line-height: 1.5;
}

.pagination-card {
  margin-bottom: 16rpx;
}

.page-error {
  text-align: center;
}

.page-error-text {
  margin-top: 8rpx;
}

.page-end {
  padding: 18rpx 0;
  text-align: center;
}

@media (max-width: 340px) {
  .messages-page {
    padding-right: 18rpx;
    padding-left: 18rpx;
  }

  .page-hero {
    min-height: 252rpx;
  }

  .hero-title {
    font-size: 42rpx;
  }

  .tool-row {
    align-items: flex-start;
  }

  .mark-all {
    max-width: 250rpx;
  }

  .message-bottom {
    align-items: flex-start;
    flex-direction: column;
  }

  .read-action,
  .detail-action {
    margin-top: 12rpx;
  }
}
