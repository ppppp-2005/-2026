page {
  background: #f6f4ec;
}

button::after {
  border: 0;
}

.detail-page {
  min-height: 100vh;
  padding: 24rpx 24rpx 56rpx;
  color: #17251d;
  background: #f6f4ec;
}

.detail-hero {
  display: flex;
  flex-direction: column;
  padding: 30rpx;
  color: #ffffff;
  background: linear-gradient(135deg, #1f7149 0%, #2e8658 72%, #bd7b38 100%);
  border-radius: 14rpx;
}

.hero-badges {
  display: flex;
  align-items: center;
}

.type-badge,
.status-badge {
  margin-right: 10rpx;
  padding: 6rpx 11rpx;
  font-size: 22rpx;
  line-height: 1.3;
  border-radius: 7rpx;
}

.type-badge {
  color: #16482f;
  background: #e8f4ed;
}

.status-badge {
  color: #4f5b53;
  background: #edf0ec;
}

.status-ongoing {
  color: #ffffff;
  background: rgba(18, 71, 44, 0.72);
}

.status-upcoming {
  color: #754411;
  background: #fff0d7;
}

.status-ended {
  color: #4f5b53;
  background: #edf0ec;
}

.event-title {
  margin-top: 24rpx;
  font-size: 42rpx;
  font-weight: 700;
  line-height: 1.3;
}

.event-summary {
  margin-top: 12rpx;
  color: rgba(255, 255, 255, 0.9);
  font-size: 26rpx;
  line-height: 1.55;
}

.truth-card,
.interest-status {
  display: flex;
  flex-direction: column;
  margin-top: 18rpx;
  padding: 20rpx 22rpx;
  border-radius: 12rpx;
}

.truth-card {
  background: #fff5e2;
  border: 1rpx solid #ecd5a8;
}

.truth-title,
.interest-title {
  font-size: 26rpx;
  font-weight: 700;
}

.truth-title {
  color: #8d5219;
}

.truth-copy,
.interest-copy {
  margin-top: 8rpx;
  font-size: 24rpx;
  line-height: 1.55;
}

.truth-copy {
  color: #745a37;
}

.detail-card {
  display: flex;
  flex-direction: column;
  margin-top: 18rpx;
  padding: 26rpx;
  background: #ffffff;
  border: 1rpx solid #e1e7de;
  border-radius: 14rpx;
}

.card-title {
  padding-left: 14rpx;
  font-size: 32rpx;
  font-weight: 700;
  line-height: 1.35;
  border-left: 7rpx solid #1f7149;
}

.detail-row {
  display: flex;
  align-items: flex-start;
  margin-top: 20rpx;
  padding-bottom: 18rpx;
  border-bottom: 1rpx solid #edf1eb;
}

.detail-row:last-child {
  padding-bottom: 0;
  border-bottom: 0;
}

.detail-label {
  flex: 0 0 auto;
  width: 168rpx;
  color: #2d4034;
  font-size: 25rpx;
  font-weight: 700;
  line-height: 1.55;
}

.detail-value {
  flex: 1;
  min-width: 0;
  color: #5d6961;
  font-size: 25rpx;
  line-height: 1.55;
}

.audience-row {
  display: flex;
  align-items: flex-start;
  margin-top: 18rpx;
}

.audience-mark {
  flex: 0 0 auto;
  width: 10rpx;
  height: 10rpx;
  margin: 14rpx 14rpx 0 2rpx;
  background: #1f7149;
  border-radius: 50%;
}

.audience-copy,
.body-copy {
  color: #56635b;
  font-size: 26rpx;
  line-height: 1.6;
}

.audience-copy {
  flex: 1;
}

.body-copy {
  display: block;
  margin-top: 16rpx;
}

.interest-status {
  color: #6f531f;
  background: #fff7e7;
  border: 1rpx solid #e9d5ae;
}

.interest-copy {
  color: #79623c;
}

.interest-status-active {
  color: #315641;
  background: #eaf5ed;
  border-color: #bfd9c7;
}

.interest-status-active .interest-copy {
  color: #5a6c60;
}

.bottom-actions,
.state-actions {
  display: flex;
  margin-top: 22rpx;
}

.signup-info-button,
.interest-button,
.button-secondary,
.button-primary {
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 1;
  min-height: 88rpx;
  margin: 0;
  padding: 15rpx 12rpx;
  font-size: 26rpx;
  font-weight: 700;
  line-height: 1.4;
  border-radius: 11rpx;
}

.signup-info-button,
.button-secondary {
  margin-right: 14rpx;
  color: #1f7149;
  background: #edf6ef;
  border: 1rpx solid #bcd6c3;
}

.interest-button,
.button-primary {
  color: #ffffff;
  background: #1f7149;
  border: 1rpx solid #1f7149;
}

.interest-button-active {
  color: #6e4d1c;
  background: #fff1d6;
  border-color: #dfc385;
}

.state-card {
  display: flex;
  align-items: center;
  flex-direction: column;
  margin-top: 80rpx;
  padding: 52rpx 28rpx;
  text-align: center;
  background: #ffffff;
  border: 1rpx solid #e1e7de;
  border-radius: 14rpx;
}

.state-card-error {
  background: #fff9f4;
  border-color: #ecd4c2;
}

.state-title {
  font-size: 32rpx;
  font-weight: 700;
}

.state-copy {
  margin-top: 12rpx;
  color: #6c776f;
  font-size: 25rpx;
  line-height: 1.5;
}

@media (max-width: 340px) {
  .detail-page {
    padding-right: 18rpx;
    padding-left: 18rpx;
  }

  .event-title {
    font-size: 38rpx;
  }

  .detail-row,
  .bottom-actions,
  .state-actions {
    flex-direction: column;
  }

  .detail-label {
    width: auto;
  }

  .detail-value {
    margin-top: 5rpx;
  }

  .signup-info-button,
  .button-secondary {
    margin-right: 0;
    margin-bottom: 12rpx;
  }
}
