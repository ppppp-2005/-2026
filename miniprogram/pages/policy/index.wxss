.policy-page {
  min-height: 100vh;
  padding: 24rpx 24rpx 48rpx;
  background: #f6f7f2;
}

.policy-hero {
  display: flex;
  align-items: stretch;
  justify-content: space-between;
  overflow: hidden;
  padding: 28rpx;
  color: #ffffff;
  background: linear-gradient(135deg, #1f7a4d 0%, #2d8a58 58%, #d78a38 100%);
  border-radius: 8rpx;
}

.hero-main {
  flex: 1;
  min-width: 0;
  padding-right: 18rpx;
}

.hero-label {
  display: inline-flex;
  padding: 8rpx 16rpx;
  color: #fff7df;
  font-size: 24rpx;
  line-height: 1.2;
  background: rgba(22, 64, 43, 0.34);
  border-radius: 8rpx;
}

.hero-title {
  margin-top: 22rpx;
  font-size: 44rpx;
  font-weight: 700;
  line-height: 1.2;
}

.hero-subtitle {
  margin-top: 12rpx;
  color: rgba(255, 255, 255, 0.92);
  font-size: 26rpx;
  line-height: 1.45;
}

.hero-count {
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 0 0 auto;
  flex-direction: column;
  width: 148rpx;
  min-height: 148rpx;
  margin-top: 6rpx;
  background: rgba(255, 255, 255, 0.16);
  border: 1rpx solid rgba(255, 255, 255, 0.32);
  border-radius: 8rpx;
}

.hero-count-number {
  font-size: 46rpx;
  font-weight: 700;
  line-height: 1;
}

.hero-count-label {
  width: 108rpx;
  margin-top: 10rpx;
  color: rgba(255, 255, 255, 0.86);
  font-size: 22rpx;
  line-height: 1.25;
  text-align: center;
}

.important-card {
  margin-top: 20rpx;
  padding: 22rpx;
  background: #fff7e8;
  border: 1rpx solid #f0d9ad;
  border-radius: 8rpx;
}

.important-top {
  display: flex;
  align-items: center;
}

.important-tag {
  flex: 0 0 auto;
  padding: 6rpx 10rpx;
  color: #ffffff;
  font-size: 22rpx;
  font-weight: 600;
  line-height: 1.2;
  background: #bd6d23;
  border-radius: 8rpx;
}

.important-title {
  margin-left: 14rpx;
  color: #6f451d;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1.3;
}

.important-text {
  display: block;
  margin-top: 14rpx;
  color: #725a40;
  font-size: 26rpx;
  line-height: 1.55;
}

.important-action {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 168rpx;
  min-height: 88rpx;
  margin-top: 18rpx;
  padding: 12rpx 20rpx;
  box-sizing: border-box;
  color: #8b501b;
  font-size: 25rpx;
  font-weight: 600;
  line-height: 1.3;
  background: #ffffff;
  border: 1rpx solid #e4c99b;
  border-radius: 8rpx;
}

.category-section {
  margin-top: 22rpx;
  padding: 24rpx 0 18rpx;
  background: #ffffff;
  border: 1rpx solid #e7ebe3;
  border-radius: 8rpx;
}

.section-heading,
.list-heading {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
}

.section-heading {
  padding: 0 22rpx;
}

.section-title {
  display: block;
  color: #16251d;
  font-size: 34rpx;
  font-weight: 700;
  line-height: 1.25;
}

.section-subtitle {
  display: block;
  margin-top: 8rpx;
  color: #778178;
  font-size: 23rpx;
  line-height: 1.35;
}

.section-side,
.result-count {
  flex: 0 0 auto;
  color: #1f7a4d;
  font-size: 24rpx;
  line-height: 1.4;
}

.category-scroll {
  width: 100%;
  margin-top: 18rpx;
  white-space: nowrap;
}

.category-row {
  display: inline-flex;
  min-width: 100%;
  padding: 0 22rpx 2rpx;
}

.category-card {
  display: inline-flex;
  align-items: center;
  flex: 0 0 auto;
  min-height: 72rpx;
  margin-right: 12rpx;
  padding: 10rpx 18rpx 10rpx 12rpx;
  color: #3e4a43;
  background: #f8faf6;
  border: 1rpx solid #dfe6dc;
  border-radius: 8rpx;
}

.category-card-active {
  color: #ffffff;
  background: #1f7a4d;
  border-color: #1f7a4d;
}

.category-mark {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 46rpx;
  height: 46rpx;
  color: #1f7a4d;
  font-size: 23rpx;
  font-weight: 700;
  background: #e8f4ed;
  border-radius: 8rpx;
}

.category-card-active .category-mark {
  color: #1f7a4d;
  background: #ffffff;
}

.category-name {
  margin-left: 10rpx;
  font-size: 26rpx;
  font-weight: 600;
  line-height: 1.25;
}

.list-heading {
  margin: 28rpx 0 16rpx;
}

.policy-list {
  display: flex;
  flex-direction: column;
}

.policy-card {
  margin-bottom: 18rpx;
  padding: 24rpx;
  background: #ffffff;
  border: 1rpx solid #e7ebe3;
  border-radius: 8rpx;
  box-shadow: 0 10rpx 24rpx rgba(31, 41, 51, 0.04);
}

.policy-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.policy-category {
  padding: 6rpx 10rpx;
  color: #1f7a4d;
  font-size: 22rpx;
  line-height: 1.2;
  background: #e8f4ed;
  border-radius: 8rpx;
}

.policy-date {
  color: #87918a;
  font-size: 22rpx;
  line-height: 1.3;
}

.policy-title {
  display: block;
  margin-top: 18rpx;
  color: #16251d;
  font-size: 34rpx;
  font-weight: 700;
  line-height: 1.3;
}

.policy-summary {
  display: block;
  margin-top: 10rpx;
  color: #566159;
  font-size: 27rpx;
  line-height: 1.5;
}

.benefit-box {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 18rpx;
  padding: 16rpx 18rpx;
  background: #f4f8f2;
  border-left: 6rpx solid #1f7a4d;
  border-radius: 4rpx 8rpx 8rpx 4rpx;
}

.benefit-label {
  color: #637067;
  font-size: 24rpx;
  line-height: 1.3;
}

.benefit-value {
  margin-left: 18rpx;
  color: #1f7a4d;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 1.3;
  text-align: right;
}

.info-row {
  display: flex;
  align-items: flex-start;
  margin-top: 18rpx;
}

.info-label {
  flex: 0 0 auto;
  width: 112rpx;
  color: #7a837d;
  font-size: 24rpx;
  line-height: 1.45;
}

.info-value {
  flex: 1;
  min-width: 0;
  color: #35423a;
  font-size: 25rpx;
  line-height: 1.45;
}

.tag-row {
  display: flex;
  flex-wrap: wrap;
  margin-top: 16rpx;
}

.policy-tag {
  margin-right: 10rpx;
  margin-bottom: 10rpx;
  padding: 7rpx 11rpx;
  color: #8d5728;
  font-size: 22rpx;
  line-height: 1.2;
  background: #fff3e7;
  border-radius: 8rpx;
}

.card-action-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 8rpx;
  padding-top: 18rpx;
  border-top: 1rpx solid #eef2ed;
}

.office-copy {
  display: flex;
  flex: 1;
  flex-direction: column;
  min-width: 0;
  padding-right: 16rpx;
}

.office-label {
  color: #87918a;
  font-size: 21rpx;
  line-height: 1.3;
}

.office-name {
  margin-top: 5rpx;
  color: #405047;
  font-size: 23rpx;
  line-height: 1.35;
}

.detail-button {
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 0 0 auto;
  min-width: 144rpx;
  min-height: 88rpx;
  padding: 12rpx 20rpx;
  box-sizing: border-box;
  color: #ffffff;
  font-size: 25rpx;
  font-weight: 600;
  line-height: 1.3;
  background: #1f7a4d;
  border-radius: 8rpx;
}

.detail-panel {
  margin-top: 20rpx;
  padding: 20rpx;
  background: #fafbf8;
  border: 1rpx solid #e3e9df;
  border-radius: 8rpx;
}

.detail-block + .detail-block {
  margin-top: 20rpx;
  padding-top: 18rpx;
  border-top: 1rpx solid #e9ede7;
}

.detail-title {
  display: block;
  color: #16251d;
  font-size: 27rpx;
  font-weight: 700;
  line-height: 1.35;
}

.detail-text {
  display: block;
  margin-top: 9rpx;
  color: #566159;
  font-size: 25rpx;
  line-height: 1.55;
}

.detail-line {
  display: flex;
  align-items: flex-start;
  margin-top: 12rpx;
}

.detail-number {
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 0 0 auto;
  width: 34rpx;
  height: 34rpx;
  margin-top: 2rpx;
  color: #86501f;
  font-size: 20rpx;
  font-weight: 700;
  line-height: 1;
  background: #f7e6d2;
  border-radius: 8rpx;
}

.detail-number-green {
  color: #1f7a4d;
  background: #e4f2e9;
}

.detail-line-text {
  flex: 1;
  min-width: 0;
  margin-left: 12rpx;
  color: #4d5951;
  font-size: 24rpx;
  line-height: 1.5;
}

.consult-button {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 88rpx;
  margin-top: 22rpx;
  padding: 12rpx 20rpx;
  box-sizing: border-box;
  color: #1f7a4d;
  font-size: 25rpx;
  font-weight: 600;
  line-height: 1.3;
  background: #ffffff;
  border: 1rpx solid #bdd8c7;
  border-radius: 8rpx;
}

.source-note {
  margin-top: 4rpx;
  padding: 22rpx;
  background: #eef1ec;
  border-radius: 8rpx;
}

.source-note-title {
  display: block;
  color: #415047;
  font-size: 25rpx;
  font-weight: 700;
  line-height: 1.35;
}

.source-note-text,
.source-note-date {
  display: block;
  margin-top: 8rpx;
  color: #707a73;
  font-size: 22rpx;
  line-height: 1.5;
}

.source-note-date {
  color: #87918a;
}
