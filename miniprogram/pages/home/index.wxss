.page {
  min-height: 100vh;
  padding: 24rpx 24rpx 48rpx;
  background: #f6f7f2;
}

.hero {
  position: relative;
  overflow: hidden;
  min-height: 340rpx;
  padding: 28rpx;
  color: #ffffff;
  background: #1f7a4d;
  border-radius: 8rpx;
}

.hero-bg {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  background: linear-gradient(135deg, #1f7a4d 0%, #2f8f5d 52%, #d88b3c 100%);
}

.field {
  position: absolute;
  bottom: -22rpx;
  width: 340rpx;
  height: 150rpx;
  border-radius: 50% 50% 0 0;
  opacity: 0.34;
}

.field-left {
  left: -72rpx;
  background: #f5c267;
}

.field-right {
  right: -86rpx;
  background: #dbe7a0;
}

.ridge {
  position: absolute;
  height: 4rpx;
  background: rgba(255, 255, 255, 0.38);
  border-radius: 999rpx;
}

.ridge-one {
  left: 260rpx;
  top: 92rpx;
  width: 250rpx;
}

.ridge-two {
  right: 70rpx;
  top: 136rpx;
  width: 170rpx;
}

.hero-top,
.hero-content {
  position: relative;
  z-index: 1;
}

.hero-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.brand-mark {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 88rpx;
  height: 88rpx;
  color: #1f7a4d;
  font-size: 34rpx;
  font-weight: 700;
  background: #ffffff;
  border: 6rpx solid rgba(255, 255, 255, 0.46);
  border-radius: 50%;
}

.login-link {
  display: flex;
  align-items: center;
  justify-content: center;
  min-width: 96rpx;
  height: 52rpx;
  margin: 0;
  padding: 0 22rpx;
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 500;
  line-height: 1;
  background: rgba(22, 64, 43, 0.22);
  border: 1rpx solid rgba(255, 255, 255, 0.36);
  border-radius: 999rpx;
  backdrop-filter: blur(8rpx);
}

.hero-content {
  margin-top: 58rpx;
}

.hero-kicker {
  display: inline-flex;
  padding: 8rpx 16rpx;
  color: #fff7df;
  font-size: 24rpx;
  line-height: 1.2;
  background: rgba(22, 64, 43, 0.38);
  border-radius: 8rpx;
}

.hero-title {
  margin-top: 18rpx;
  font-size: 52rpx;
  font-weight: 700;
  line-height: 1.18;
}

.hero-subtitle {
  margin-top: 12rpx;
  color: rgba(255, 255, 255, 0.92);
  font-size: 28rpx;
  line-height: 1.5;
}

.search-box {
  display: flex;
  align-items: center;
  min-height: 92rpx;
  margin-top: 24rpx;
  padding: 0 28rpx;
  background: #ffffff;
  border: 1rpx solid #e3e8df;
  border-radius: 8rpx;
  box-shadow: 0 10rpx 24rpx rgba(31, 41, 51, 0.05);
}

.search-icon {
  position: relative;
  flex: 0 0 auto;
  width: 30rpx;
  height: 30rpx;
  margin-right: 18rpx;
  border: 4rpx solid #1f7a4d;
  border-radius: 50%;
}

.search-icon::after {
  position: absolute;
  right: -11rpx;
  bottom: -8rpx;
  width: 16rpx;
  height: 4rpx;
  content: "";
  background: #1f7a4d;
  border-radius: 99rpx;
  transform: rotate(45deg);
}

.search-placeholder {
  color: #8a928c;
  font-size: 28rpx;
  line-height: 1.4;
}

.section {
  margin-top: 24rpx;
  padding: 28rpx;
  background: #ffffff;
  border: 1rpx solid #e7ebe3;
  border-radius: 8rpx;
}

.entry-section {
  padding: 28rpx 20rpx 18rpx;
}

.entry-header {
  padding: 0 8rpx;
}

.entry-card-grid {
  display: flex;
  flex-wrap: wrap;
  margin: -9rpx;
}

.entry-card {
  position: relative;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  width: calc(50% - 18rpx);
  min-height: 146rpx;
  margin: 9rpx;
  padding: 20rpx 18rpx;
  min-width: 0;
  border: 1rpx solid rgba(31, 41, 51, 0.06);
  border-radius: 8rpx;
  box-shadow: 0 8rpx 18rpx rgba(31, 41, 51, 0.04);
}

.entry-card:active {
  opacity: 0.82;
}

.entry-card-disabled {
  opacity: 0.76;
}

.entry-stamp {
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 0 0 auto;
  width: 68rpx;
  height: 68rpx;
  margin-right: 14rpx;
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 700;
  border-radius: 8rpx;
}

.entry-copy {
  flex: 1;
  min-width: 0;
}

.entry-title-row {
  display: flex;
  align-items: center;
  min-width: 0;
}

.entry-title {
  color: #16251d;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1.25;
}

.entry-badge {
  flex: 0 0 auto;
  max-width: 80rpx;
  margin-left: 8rpx;
  padding: 4rpx 8rpx;
  overflow: hidden;
  font-size: 20rpx;
  line-height: 1.2;
  white-space: nowrap;
  text-overflow: ellipsis;
  background: rgba(255, 255, 255, 0.72);
  border-radius: 8rpx;
}

.entry-description {
  display: block;
  margin-top: 10rpx;
  color: #28352e;
  font-size: 24rpx;
  line-height: 1.35;
}

.entry-arrow {
  flex: 0 0 auto;
  margin-left: 8rpx;
  color: #7a837d;
  font-size: 28rpx;
  line-height: 1;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 18rpx;
}

.section-title {
  color: #16251d;
  font-size: 32rpx;
  font-weight: 700;
  line-height: 1.3;
}

.section-more {
  display: flex;
  align-items: center;
  justify-content: center;
  min-width: 88rpx;
  min-height: 88rpx;
  margin: -24rpx -12rpx -24rpx 0;
  padding: 0 12rpx;
  color: #1f7a4d;
  font-size: 24rpx;
  line-height: 1.3;
}

.news-list {
  display: flex;
  flex-direction: column;
}

.news-item {
  display: flex;
  align-items: flex-start;
  padding: 20rpx 0;
  border-top: 1rpx solid #edf0eb;
}

.news-item:first-child {
  border-top: 0;
}

.news-tag {
  flex: 0 0 auto;
  min-width: 90rpx;
  margin-right: 18rpx;
  padding: 6rpx 10rpx;
  color: #1f7a4d;
  font-size: 22rpx;
  line-height: 1.2;
  text-align: center;
  background: #e8f4ed;
  border-radius: 8rpx;
}

.news-main {
  display: flex;
  flex: 1;
  flex-direction: column;
  min-width: 0;
}

.news-title {
  color: #26342d;
  font-size: 28rpx;
  line-height: 1.45;
}

.news-meta {
  margin-top: 8rpx;
  color: #7a837d;
  font-size: 23rpx;
  line-height: 1.3;
}

.service-section {
  margin-bottom: 16rpx;
}

.service-grid {
  display: flex;
  flex-wrap: wrap;
  margin: -9rpx;
}

.service-card {
  box-sizing: border-box;
  width: calc(50% - 18rpx);
  min-height: 164rpx;
  margin: 9rpx;
  padding: 20rpx;
  background: #f8faf6;
  border: 1rpx solid #e4eadf;
  border-radius: 8rpx;
}

.service-card:active {
  opacity: 0.82;
}

.service-card-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 8rpx;
}

.service-title {
  color: #16251d;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 1.3;
}

.service-badge {
  flex: 0 0 auto;
  padding: 4rpx 8rpx;
  color: #a45f3d;
  font-size: 20rpx;
  line-height: 1.2;
  background: #fff1e8;
  border-radius: 8rpx;
}

.service-desc {
  display: block;
  margin-top: 14rpx;
  color: #69746d;
  font-size: 24rpx;
  line-height: 1.45;
}
