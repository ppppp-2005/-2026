.page {
  min-height: 100vh;
  padding: 24rpx 24rpx 56rpx;
  color: #183126;
  background: #f6f7f2;
  box-sizing: border-box;
}

.hero {
  padding: 30rpx;
  color: #ffffff;
  background: #1f7a4d;
  border-radius: 10rpx;
}

.hero-top,
.section-row,
.action-card,
.job-top,
.job-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.hero-label,
.demo-badge {
  font-size: 24rpx;
}

.demo-badge {
  padding: 8rpx 12rpx;
  background: rgba(255, 255, 255, 0.18);
  border: 1rpx solid rgba(255, 255, 255, 0.36);
  border-radius: 8rpx;
}

.hero-title,
.hero-subtitle,
.section-title,
.section-subtitle,
.company-name,
.profile-line,
.action-title,
.action-text,
.job-title,
.job-salary,
.job-line {
  display: block;
}

.hero-title {
  margin-top: 24rpx;
  font-size: 44rpx;
  font-weight: 700;
  line-height: 1.22;
}

.hero-subtitle {
  margin-top: 14rpx;
  color: #e8f4ed;
  font-size: 27rpx;
  line-height: 1.5;
}

.card {
  background: #ffffff;
  border: 1rpx solid #e2e9e2;
  border-radius: 10rpx;
}

.state-tools,
.state-card {
  margin-top: 20rpx;
  padding: 24rpx;
  background: #ffffff;
  border: 1rpx solid #e2e9e2;
  border-radius: 10rpx;
}

.tool-label,
.state-title,
.state-text {
  display: block;
}

.tool-label,
.state-title {
  font-size: 28rpx;
  font-weight: 700;
}

.tool-buttons {
  display: flex;
  flex-wrap: wrap;
  margin-top: 14rpx;
  gap: 10rpx;
}

.mode-button,
.primary-state-button {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 88rpx;
  margin: 0;
  padding: 0 20rpx;
  font-size: 25rpx;
  border-radius: 8rpx;
}

.mode-button::after,
.primary-state-button::after {
  border: 0;
}

.mode-button {
  color: #536259;
  background: #edf1ec;
}

.mode-button.active,
.primary-state-button {
  color: #ffffff;
  background: #1f7a4d;
}

.state-card {
  padding-top: 48rpx;
  padding-bottom: 48rpx;
  text-align: center;
}

.state-text {
  margin-top: 12rpx;
  color: #66736a;
  font-size: 25rpx;
  line-height: 1.5;
}

.primary-state-button {
  width: 100%;
  margin-top: 22rpx;
}

.profile-card {
  margin-top: 20rpx;
  padding: 26rpx;
}

.section-copy,
.action-copy {
  flex: 1;
  min-width: 0;
  padding-right: 18rpx;
}

.section-title {
  font-size: 34rpx;
  font-weight: 700;
  line-height: 1.3;
}

.section-subtitle {
  margin-top: 6rpx;
  color: #68776d;
  font-size: 24rpx;
  line-height: 1.45;
}

.small-button,
.primary-small,
.link-button,
.reset-button {
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0;
  padding: 0 20rpx;
  border-radius: 8rpx;
}

.small-button::after,
.primary-small::after,
.link-button::after,
.reset-button::after {
  border: 0;
}

.small-button {
  min-height: 88rpx;
  color: #1f7a4d;
  font-size: 25rpx;
  background: #e8f4ed;
}

.progress-track {
  height: 14rpx;
  margin-top: 22rpx;
  overflow: hidden;
  background: #e7ece7;
  border-radius: 8rpx;
}

.progress-fill {
  height: 100%;
  background: #1f7a4d;
}

.profile-summary {
  margin-top: 22rpx;
}

.company-name {
  font-size: 32rpx;
  font-weight: 700;
}

.profile-line {
  margin-top: 9rpx;
  color: #4f6056;
  font-size: 25rpx;
  line-height: 1.45;
}

.profile-form {
  margin-top: 22rpx;
}

.field {
  margin-top: 20rpx;
}

.field:first-child {
  margin-top: 0;
}

.field-label {
  display: block;
  margin-bottom: 10rpx;
  font-size: 26rpx;
  font-weight: 600;
}

.required {
  color: #b94a3a;
}

.field-input {
  min-height: 88rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  background: #fafbf8;
  border: 1rpx solid #cfd9d0;
  border-radius: 8rpx;
  box-sizing: border-box;
}

.reset-button {
  width: 100%;
  min-height: 88rpx;
  margin-top: 22rpx;
  color: #4f6056;
  font-size: 26rpx;
  background: #f0f3ee;
}

.honest-note {
  margin-top: 22rpx;
  padding: 18rpx;
  color: #78571e;
  font-size: 24rpx;
  line-height: 1.5;
  background: #fff7e8;
  border: 1rpx solid #f0dfbd;
  border-radius: 8rpx;
}

.summary-grid {
  display: flex;
  margin-top: 20rpx;
  background: #ffffff;
  border: 1rpx solid #e2e9e2;
  border-radius: 10rpx;
}

.summary-item {
  flex: 1;
  min-width: 0;
  padding: 24rpx 8rpx;
  text-align: center;
  border-left: 1rpx solid #e8ede8;
}

.summary-item:first-child {
  border-left: 0;
}

.summary-value {
  color: #1f7a4d;
  font-size: 38rpx;
  font-weight: 700;
}

.summary-unit,
.summary-label {
  color: #607067;
  font-size: 22rpx;
}

.summary-label {
  display: block;
  margin-top: 8rpx;
}

.section-heading {
  margin: 32rpx 4rpx 16rpx;
}

.action-card {
  margin-bottom: 14rpx;
  padding: 22rpx;
}

.action-title,
.job-title {
  font-size: 30rpx;
  font-weight: 700;
}

.action-text {
  margin-top: 7rpx;
  color: #68776d;
  font-size: 24rpx;
  line-height: 1.4;
}

.primary-small,
.link-button {
  min-height: 88rpx;
  color: #ffffff;
  font-size: 25rpx;
  background: #1f7a4d;
}

.job-card {
  margin-bottom: 16rpx;
  padding: 24rpx;
}

.job-status {
  margin-left: 18rpx;
  color: #1f7a4d;
  font-size: 22rpx;
}

.job-salary {
  margin-top: 12rpx;
  color: #d56722;
  font-size: 29rpx;
  font-weight: 700;
}

.job-line,
.job-count {
  margin-top: 9rpx;
  color: #5c6b62;
  font-size: 24rpx;
  line-height: 1.45;
}

.job-bottom {
  margin-top: 18rpx;
  padding-top: 18rpx;
  border-top: 1rpx solid #edf1ed;
}

@media (max-width: 360px) {
  .action-card,
  .section-row {
    align-items: stretch;
    flex-direction: column;
  }

  .small-button,
  .primary-small {
    width: 100%;
    margin-top: 16rpx;
  }
}
