.labor-page {
  min-height: 100vh;
  padding: 24rpx 24rpx 48rpx;
  background: #f6f7f2;
}

.labor-hero {
  overflow: hidden;
  padding: 28rpx;
  color: #ffffff;
  background: linear-gradient(135deg, #1f7a4d 0%, #2d8a58 62%, #c77a2b 100%);
  border-radius: 8rpx;
}

.hero-copy {
  min-width: 0;
}

.hero-eyebrow {
  display: inline-flex;
  padding: 8rpx 16rpx;
  color: #fff7df;
  font-size: 24rpx;
  line-height: 1.2;
  background: rgba(22, 64, 43, 0.34);
  border-radius: 8rpx;
}

.hero-title {
  margin-top: 20rpx;
  font-size: 48rpx;
  font-weight: 700;
  line-height: 1.18;
}

.hero-subtitle {
  margin-top: 12rpx;
  color: rgba(255, 255, 255, 0.92);
  font-size: 27rpx;
  line-height: 1.5;
}

.hero-summary {
  display: flex;
  align-items: stretch;
  margin-top: 26rpx;
  background: rgba(255, 255, 255, 0.14);
  border: 1rpx solid rgba(255, 255, 255, 0.28);
  border-radius: 8rpx;
}

.summary-item {
  display: flex;
  align-items: baseline;
  flex: 1;
  justify-content: center;
  padding: 20rpx 12rpx;
}

.summary-number {
  font-size: 38rpx;
  font-weight: 700;
  line-height: 1;
}

.summary-label {
  margin-left: 8rpx;
  color: rgba(255, 255, 255, 0.86);
  font-size: 23rpx;
  line-height: 1.2;
}

.summary-divider {
  width: 1rpx;
  margin: 16rpx 0;
  background: rgba(255, 255, 255, 0.24);
}

.filter-section {
  margin-top: 24rpx;
  padding: 24rpx 20rpx 20rpx;
  background: #ffffff;
  border: 1rpx solid #e4e9e1;
  border-radius: 8rpx;
}

.section-heading,
.result-heading,
.card-topline,
.card-action-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.section-heading {
  padding: 0 4rpx;
}

.section-title {
  display: block;
  color: #16251d;
  font-size: 34rpx;
  font-weight: 700;
  line-height: 1.25;
}

.section-help {
  color: #6f7a73;
  font-size: 23rpx;
  line-height: 1.3;
}

.filter-grid {
  display: flex;
  flex-wrap: wrap;
  margin: 14rpx -7rpx -7rpx;
}

.filter-card {
  display: flex;
  flex-direction: column;
  justify-content: center;
  width: calc(50% - 14rpx);
  min-height: 110rpx;
  margin: 7rpx;
  padding: 16rpx 18rpx;
  background: #f8faf6;
  border: 2rpx solid #e1e8df;
  border-radius: 8rpx;
}

.filter-card:active {
  opacity: 0.82;
}

.filter-card-active {
  background: #e8f4ed;
  border-color: #1f7a4d;
}

.filter-name {
  color: #1e2e25;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 1.25;
}

.filter-card-active .filter-name {
  color: #17663e;
}

.filter-description {
  margin-top: 8rpx;
  color: #6e7871;
  font-size: 22rpx;
  line-height: 1.3;
}

.safety-tip {
  margin-top: 18rpx;
  padding: 20rpx 22rpx;
  background: #fff7e8;
  border: 1rpx solid #f0dab0;
  border-radius: 8rpx;
}

.safety-title {
  display: block;
  color: #8e5115;
  font-size: 26rpx;
  font-weight: 700;
  line-height: 1.35;
}

.safety-text {
  display: block;
  margin-top: 8rpx;
  color: #735b3d;
  font-size: 24rpx;
  line-height: 1.55;
}

.result-heading {
  align-items: flex-end;
  margin: 28rpx 2rpx 16rpx;
}

.result-label {
  display: block;
  margin-top: 7rpx;
  color: #778178;
  font-size: 23rpx;
  line-height: 1.3;
}

.mock-label {
  flex: 0 0 auto;
  padding: 6rpx 10rpx;
  color: #7b6a52;
  font-size: 21rpx;
  line-height: 1.2;
  background: #f1ede5;
  border-radius: 8rpx;
}

.demand-list {
  display: flex;
  flex-direction: column;
}

.demand-card {
  margin-bottom: 18rpx;
  padding: 24rpx;
  background: #ffffff;
  border: 1rpx solid #e4e9e1;
  border-radius: 8rpx;
  box-shadow: 0 10rpx 24rpx rgba(31, 41, 51, 0.04);
}

.category-badge {
  padding: 6rpx 12rpx;
  font-size: 22rpx;
  font-weight: 600;
  line-height: 1.2;
  border-radius: 8rpx;
}

.category-long {
  color: #17663e;
  background: #e7f3eb;
}

.category-short {
  color: #8a5b17;
  background: #fff3d9;
}

.category-urgent {
  color: #a23d30;
  background: #ffebe7;
}

.updated-text {
  color: #7a847d;
  font-size: 22rpx;
  line-height: 1.3;
}

.demand-title {
  margin-top: 18rpx;
  color: #16251d;
  font-size: 34rpx;
  font-weight: 700;
  line-height: 1.3;
}

.employer-name {
  margin-top: 8rpx;
  color: #67736b;
  font-size: 24rpx;
  line-height: 1.4;
}

.key-facts {
  display: flex;
  align-items: stretch;
  margin-top: 20rpx;
  padding: 18rpx 0;
  background: #f8faf6;
  border: 1rpx solid #e7ece4;
  border-radius: 8rpx;
}

.fact-item {
  display: flex;
  flex: 1;
  flex-direction: column;
  min-width: 0;
  padding: 0 12rpx;
}

.fact-item-middle {
  border-right: 1rpx solid #dfe6dd;
  border-left: 1rpx solid #dfe6dd;
}

.fact-label {
  color: #7a847d;
  font-size: 21rpx;
  line-height: 1.2;
}

.fact-value {
  margin-top: 8rpx;
  color: #26342d;
  font-size: 24rpx;
  font-weight: 600;
  line-height: 1.35;
  word-break: break-all;
}

.fact-value-strong {
  color: #1f7a4d;
  font-size: 27rpx;
}

.fact-value-pay {
  color: #d6681b;
}

.detail-row {
  display: flex;
  align-items: flex-start;
  margin-top: 16rpx;
}

.detail-label {
  flex: 0 0 auto;
  width: 116rpx;
  color: #59675f;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 1.5;
}

.detail-value {
  flex: 1;
  min-width: 0;
  color: #34423a;
  font-size: 25rpx;
  line-height: 1.5;
}

.benefit-row {
  display: flex;
  flex-wrap: wrap;
  margin-top: 16rpx;
}

.benefit-tag {
  margin-right: 10rpx;
  margin-bottom: 10rpx;
  padding: 8rpx 12rpx;
  color: #1f6e49;
  font-size: 22rpx;
  line-height: 1.2;
  background: #eaf4ed;
  border-radius: 8rpx;
}

.card-action-row {
  margin-top: 8rpx;
  padding-top: 18rpx;
  border-top: 1rpx solid #edf1eb;
}

.contact-note {
  flex: 1;
  min-width: 0;
  padding-right: 16rpx;
  color: #7a847d;
  font-size: 22rpx;
  line-height: 1.35;
}

.contact-button {
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 0 0 auto;
  min-width: 154rpx;
  min-height: 88rpx;
  padding: 12rpx 20rpx;
  box-sizing: border-box;
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 600;
  line-height: 1.3;
  background: #1f7a4d;
  border-radius: 8rpx;
}

.contact-button:active {
  opacity: 0.82;
}
