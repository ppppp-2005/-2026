.campus-page {
  min-height: 100vh;
  padding: 24rpx 24rpx 48rpx;
  background: #f6f7f2;
}

.campus-hero {
  display: flex;
  align-items: stretch;
  justify-content: space-between;
  overflow: hidden;
  padding: 28rpx;
  color: #ffffff;
  background: linear-gradient(135deg, #1f7a4d 0%, #2f8f5d 62%, #d88b3c 100%);
  border-radius: 8rpx;
}

.hero-main {
  flex: 1;
  min-width: 0;
  padding-right: 20rpx;
}

.hero-label {
  display: inline-flex;
  padding: 8rpx 16rpx;
  color: #fff7df;
  font-size: 24rpx;
  line-height: 1.2;
  background: rgba(22, 64, 43, 0.36);
  border-radius: 8rpx;
}

.hero-title {
  display: block;
  margin-top: 20rpx;
  font-size: 44rpx;
  font-weight: 700;
  line-height: 1.22;
}

.hero-subtitle {
  display: block;
  margin-top: 12rpx;
  color: rgba(255, 255, 255, 0.92);
  font-size: 26rpx;
  line-height: 1.5;
}

.hero-summary {
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 0 0 auto;
  flex-direction: column;
  width: 148rpx;
  min-height: 148rpx;
  background: rgba(255, 255, 255, 0.16);
  border: 1rpx solid rgba(255, 255, 255, 0.32);
  border-radius: 8rpx;
}

.hero-summary-number {
  font-size: 46rpx;
  font-weight: 700;
  line-height: 1;
}

.hero-summary-text {
  margin-top: 10rpx;
  color: rgba(255, 255, 255, 0.88);
  font-size: 22rpx;
  line-height: 1.3;
  text-align: center;
}

.notice-bar {
  display: flex;
  align-items: flex-start;
  margin-top: 18rpx;
  padding: 18rpx 22rpx;
  background: #fff7e8;
  border: 1rpx solid #f3dfb7;
  border-radius: 8rpx;
}

.notice-title {
  flex: 0 0 auto;
  color: #995b19;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 1.45;
}

.notice-text {
  flex: 1;
  min-width: 0;
  margin-left: 14rpx;
  color: #765b38;
  font-size: 23rpx;
  line-height: 1.45;
}

.section-head {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  margin-top: 28rpx;
  margin-bottom: 16rpx;
}

.section-title {
  display: block;
  color: #16251d;
  font-size: 34rpx;
  font-weight: 700;
  line-height: 1.3;
}

.section-subtitle {
  display: block;
  margin-top: 8rpx;
  color: #778178;
  font-size: 23rpx;
  line-height: 1.35;
}

.section-count {
  flex: 0 0 auto;
  color: #1f7a4d;
  font-size: 24rpx;
  line-height: 1.4;
}

.event-list,
.opportunity-list {
  display: flex;
  flex-direction: column;
}

.event-card,
.opportunity-card {
  margin-bottom: 18rpx;
  padding: 24rpx;
  background: #ffffff;
  border: 1rpx solid #e5eae2;
  border-radius: 8rpx;
  box-shadow: 0 10rpx 24rpx rgba(31, 41, 51, 0.04);
}

.event-date {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #edf1eb;
}

.event-date-main {
  color: #1f7a4d;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1.3;
}

.event-time {
  color: #56635b;
  font-size: 26rpx;
  font-weight: 600;
  line-height: 1.3;
}

.event-title {
  display: block;
  margin-top: 18rpx;
  color: #16251d;
  font-size: 32rpx;
  font-weight: 700;
  line-height: 1.4;
}

.event-organizer {
  display: block;
  margin-top: 8rpx;
  color: #788179;
  font-size: 23rpx;
  line-height: 1.4;
}

.event-info-row {
  display: flex;
  align-items: flex-start;
  margin-top: 14rpx;
}

.event-info-label {
  flex: 0 0 auto;
  width: 76rpx;
  color: #5d685f;
  font-size: 25rpx;
  font-weight: 700;
  line-height: 1.45;
}

.event-info-value {
  flex: 1;
  min-width: 0;
  color: #344139;
  font-size: 25rpx;
  line-height: 1.45;
}

.event-action-row,
.opportunity-action-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 18rpx;
  padding-top: 18rpx;
  border-top: 1rpx solid #edf1eb;
}

.event-company-count,
.deadline-text {
  color: #7b857e;
  font-size: 23rpx;
  line-height: 1.35;
}

.event-action,
.opportunity-action {
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 0 0 auto;
  min-width: 150rpx;
  min-height: 88rpx;
  margin: 0;
  padding: 12rpx 24rpx;
  box-sizing: border-box;
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 600;
  line-height: 1.3;
  background: #1f7a4d;
  border-radius: 8rpx;
}

.event-action::after,
.opportunity-action::after,
.filter-button::after {
  border: 0;
}

.event-action:active,
.opportunity-action:active,
.filter-button:active {
  opacity: 0.82;
}

.opportunity-head {
  margin-top: 18rpx;
}

.filter-row {
  display: flex;
  margin: 0 -6rpx 18rpx;
}

.filter-button {
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 1;
  min-height: 88rpx;
  margin: 0 6rpx;
  padding: 12rpx;
  box-sizing: border-box;
  color: #425047;
  font-size: 25rpx;
  line-height: 1.3;
  background: #ffffff;
  border: 1rpx solid #dce5dc;
  border-radius: 8rpx;
}

.filter-button-active {
  color: #ffffff;
  background: #1f7a4d;
  border-color: #1f7a4d;
}

.opportunity-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
}

.opportunity-title-wrap {
  flex: 1;
  min-width: 0;
  padding-right: 18rpx;
}

.opportunity-type {
  display: inline-flex;
  padding: 5rpx 10rpx;
  color: #1f7a4d;
  font-size: 21rpx;
  line-height: 1.2;
  background: #e8f4ed;
  border-radius: 8rpx;
}

.opportunity-title {
  display: block;
  margin-top: 10rpx;
  color: #16251d;
  font-size: 32rpx;
  font-weight: 700;
  line-height: 1.35;
}

.opportunity-pay {
  flex: 0 0 auto;
  color: #df6d1d;
  font-size: 29rpx;
  font-weight: 700;
  line-height: 1.4;
}

.opportunity-company {
  display: block;
  margin-top: 12rpx;
  color: #657069;
  font-size: 24rpx;
  line-height: 1.4;
}

.opportunity-facts {
  display: flex;
  flex-wrap: wrap;
  margin-top: 16rpx;
  padding: 14rpx 16rpx;
  background: #f7f9f5;
  border-radius: 8rpx;
}

.fact-item {
  display: flex;
  align-items: center;
  width: 50%;
  min-width: 0;
  margin: 5rpx 0;
}

.fact-label {
  flex: 0 0 auto;
  margin-right: 10rpx;
  color: #7b857e;
  font-size: 22rpx;
  line-height: 1.35;
}

.fact-value {
  min-width: 0;
  color: #354139;
  font-size: 23rpx;
  line-height: 1.35;
}

.label-row {
  display: flex;
  flex-wrap: wrap;
  margin-top: 16rpx;
}

.opportunity-label {
  margin-right: 10rpx;
  margin-bottom: 8rpx;
  padding: 7rpx 12rpx;
  color: #526058;
  font-size: 22rpx;
  line-height: 1.2;
  background: #f2f5f0;
  border: 1rpx solid #e2e8df;
  border-radius: 8rpx;
}

.bottom-tip {
  padding: 20rpx 18rpx;
  color: #788179;
  font-size: 23rpx;
  line-height: 1.5;
  text-align: center;
  background: #eef3ec;
  border-radius: 8rpx;
}
