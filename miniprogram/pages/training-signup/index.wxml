<view class="training-page">
  <view class="training-hero">
    <view class="hero-copy">
      <text class="hero-label">{{trainingSignup.header.label}}</text>
      <view class="hero-title">{{trainingSignup.header.title}}</view>
      <view class="hero-subtitle">{{trainingSignup.header.subtitle}}</view>
    </view>
    <view class="hero-count">
      <text class="hero-count-number">{{trainingSignup.header.availableCount}}</text>
      <text class="hero-count-label">{{trainingSignup.header.availableLabel}}</text>
    </view>
  </view>

  <view class="signup-notice">
    <text class="notice-title">{{trainingSignup.notice.title}}</text>
    <text class="notice-text">{{trainingSignup.notice.text}}</text>
  </view>

  <scroll-view class="filter-scroll" scroll-x="true" show-scrollbar="false">
    <view class="filter-row">
      <view
        class="filter-chip {{activeStatus == item.id ? 'filter-chip-active' : ''}}"
        bindtap="onStatusFilterTap"
        data-status="{{item.id}}"
        wx:for="{{trainingSignup.filters}}"
        wx:key="id"
      >
        {{item.name}}
      </view>
    </view>
  </scroll-view>

  <view class="section-head">
    <view>
      <text class="section-title">近期培训班</text>
      <text class="section-subtitle">共找到 {{visibleSessions.length}} 个班次</text>
    </view>
    <text class="section-side">贵州本地</text>
  </view>

  <view class="session-list" wx:if="{{visibleSessions.length}}">
    <view class="session-card session-card-{{item.status}}" wx:for="{{visibleSessions}}" wx:key="id">
      <view class="card-head">
        <view class="course-copy">
          <text class="course-category">{{item.category}}</text>
          <text class="course-title">{{item.title}}</text>
        </view>
        <view class="status-badge status-badge-{{item.status}}">
          <text class="status-name">{{item.statusLabel}}</text>
          <text class="status-hint">{{item.statusHint}}</text>
        </view>
      </view>

      <text class="course-summary">{{item.summary}}</text>

      <view class="detail-list">
        <view class="detail-row">
          <text class="detail-label">名额</text>
          <text class="detail-value capacity-{{item.status}}">{{item.capacity.display}}</text>
        </view>
        <view class="detail-row">
          <text class="detail-label">开班</text>
          <text class="detail-value">{{item.schedule.dateText}}</text>
        </view>
        <view class="detail-row">
          <text class="detail-label">上课</text>
          <text class="detail-value">{{item.schedule.timeText}}</text>
        </view>
        <view class="detail-row">
          <text class="detail-label">地点</text>
          <view class="detail-value detail-place">
            <text>{{item.venue.name}}</text>
            <text class="detail-subvalue">{{item.venue.address}}</text>
          </view>
        </view>
        <view class="detail-row">
          <text class="detail-label">费用</text>
          <text class="detail-value fee-value">{{item.fee.display}}</text>
        </view>
      </view>

      <view class="condition-box">
        <text class="condition-title">报名条件</text>
        <view class="condition-list">
          <text class="condition-item" wx:for="{{item.eligibility}}" wx:for-item="condition" wx:key="*this">{{condition}}</text>
        </view>
      </view>

      <text class="provider">承办单位：{{item.provider}}</text>

      <view class="card-action-row">
        <text class="action-note">{{trainingSignup.action.note}}</text>
        <view
          class="signup-button signup-button-{{item.status}}"
          bindtap="onSignupTap"
          data-session-id="{{item.id}}"
        >
          {{item.buttonText}}
        </view>
      </view>
    </view>
  </view>

  <view class="empty-state" wx:else>
    <text class="empty-title">暂无这个状态的班次</text>
    <text class="empty-text">请查看其他分类。</text>
  </view>
</view>
