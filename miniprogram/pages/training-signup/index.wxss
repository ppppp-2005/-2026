.training-page {
  min-height: 100vh;
  padding: 24rpx 24rpx 48rpx;
  background: #f6f7f2;
}

.training-hero {
  display: flex;
  align-items: stretch;
  justify-content: space-between;
  overflow: hidden;
  padding: 28rpx;
  color: #ffffff;
  background: linear-gradient(135deg, #1f7a4d 0%, #2d8a58 62%, #d78a38 100%);
  border-radius: 8rpx;
}

.hero-copy {
  min-width: 0;
  padding-right: 18rpx;
}

.hero-label {
  display: inline-flex;
  padding: 8rpx 16rpx;
  color: #fff7df;
  font-size: 24rpx;
  line-height: 1.2;
  background: rgba(22, 64, 43, 0.34);
  border-radius: 8rpx;
}

.hero-title {
  margin-top: 22rpx;
  font-size: 46rpx;
  font-weight: 700;
  line-height: 1.18;
}

.hero-subtitle {
  margin-top: 12rpx;
  color: rgba(255, 255, 255, 0.92);
  font-size: 26rpx;
  line-height: 1.45;
}

.hero-count {
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 0 0 auto;
  flex-direction: column;
  width: 148rpx;
  min-height: 148rpx;
  margin-top: 6rpx;
  padding: 12rpx;
  text-align: center;
  background: rgba(255, 255, 255, 0.16);
  border: 1rpx solid rgba(255, 255, 255, 0.32);
  border-radius: 8rpx;
}

.hero-count-number {
  font-size: 46rpx;
  font-weight: 700;
  line-height: 1;
}

.hero-count-label {
  margin-top: 10rpx;
  color: rgba(255, 255, 255, 0.88);
  font-size: 22rpx;
  line-height: 1.25;
}

.signup-notice {
  display: flex;
  align-items: flex-start;
  margin-top: 20rpx;
  padding: 20rpx 22rpx;
  background: #fff7e8;
  border: 1rpx solid #f3dfb7;
  border-radius: 8rpx;
}

.notice-title {
  flex: 0 0 auto;
  color: #935414;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 1.45;
}

.notice-text {
  flex: 1;
  min-width: 0;
  margin-left: 14rpx;
  color: #745934;
  font-size: 24rpx;
  line-height: 1.45;
}

.filter-scroll {
  width: 100%;
  margin-top: 20rpx;
  white-space: nowrap;
}

.filter-row {
  display: inline-flex;
  min-width: 100%;
}

.filter-chip {
  flex: 0 0 auto;
  margin-right: 12rpx;
  padding: 15rpx 24rpx;
  color: #3f4a44;
  font-size: 26rpx;
  line-height: 1.2;
  background: #ffffff;
  border: 1rpx solid #dde5dc;
  border-radius: 8rpx;
}

.filter-chip-active {
  color: #ffffff;
  background: #1f7a4d;
  border-color: #1f7a4d;
}

.section-head {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  margin-top: 28rpx;
  margin-bottom: 16rpx;
}

.section-title {
  display: block;
  color: #16251d;
  font-size: 34rpx;
  font-weight: 700;
  line-height: 1.25;
}

.section-subtitle {
  display: block;
  margin-top: 8rpx;
  color: #778178;
  font-size: 23rpx;
  line-height: 1.35;
}

.section-side {
  flex: 0 0 auto;
  color: #1f7a4d;
  font-size: 24rpx;
  line-height: 1.4;
}

.session-list {
  display: flex;
  flex-direction: column;
}

.session-card {
  margin-bottom: 18rpx;
  padding: 24rpx;
  background: #ffffff;
  border: 1rpx solid #e7ebe3;
  border-left: 6rpx solid #1f7a4d;
  border-radius: 8rpx;
  box-shadow: 0 10rpx 24rpx rgba(31, 41, 51, 0.04);
}

.session-card-limited {
  border-left-color: #d17b26;
}

.session-card-ended {
  border-left-color: #929b95;
}

.card-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
}

.course-copy {
  display: flex;
  flex: 1;
  flex-direction: column;
  min-width: 0;
  padding-right: 18rpx;
}

.course-category {
  color: #1f7a4d;
  font-size: 22rpx;
  font-weight: 600;
  line-height: 1.3;
}

.course-title {
  margin-top: 8rpx;
  color: #16251d;
  font-size: 34rpx;
  font-weight: 700;
  line-height: 1.3;
}

.status-badge {
  display: flex;
  align-items: center;
  flex: 0 0 auto;
  flex-direction: column;
  min-width: 116rpx;
  padding: 10rpx 12rpx;
  color: #1f7a4d;
  background: #e8f4ed;
  border-radius: 8rpx;
}

.status-badge-limited {
  color: #a25a16;
  background: #fff0dc;
}

.status-badge-ended {
  color: #69736d;
  background: #edf0ed;
}

.status-name {
  font-size: 23rpx;
  font-weight: 700;
  line-height: 1.25;
}

.status-hint {
  margin-top: 5rpx;
  font-size: 19rpx;
  line-height: 1.25;
}

.course-summary {
  display: block;
  margin-top: 18rpx;
  color: #526058;
  font-size: 26rpx;
  line-height: 1.5;
}

.detail-list {
  margin-top: 20rpx;
  padding: 8rpx 20rpx;
  background: #f8faf6;
  border: 1rpx solid #e9eee6;
  border-radius: 8rpx;
}

.detail-row {
  display: flex;
  align-items: flex-start;
  padding: 14rpx 0;
  border-top: 1rpx solid #e8ede5;
}

.detail-row:first-child {
  border-top: 0;
}

.detail-label {
  flex: 0 0 auto;
  width: 82rpx;
  color: #758078;
  font-size: 24rpx;
  line-height: 1.4;
}

.detail-value {
  flex: 1;
  min-width: 0;
  color: #26342d;
  font-size: 26rpx;
  font-weight: 600;
  line-height: 1.4;
}

.capacity-open {
  color: #1f7a4d;
}

.capacity-limited {
  color: #bd681e;
}

.capacity-ended {
  color: #707a74;
}

.detail-place {
  display: flex;
  flex-direction: column;
}

.detail-subvalue {
  margin-top: 5rpx;
  color: #778178;
  font-size: 23rpx;
  font-weight: 400;
  line-height: 1.35;
}

.fee-value {
  color: #a45f22;
}

.condition-box {
  margin-top: 18rpx;
}

.condition-title {
  display: block;
  color: #26342d;
  font-size: 26rpx;
  font-weight: 700;
  line-height: 1.35;
}

.condition-list {
  display: flex;
  flex-wrap: wrap;
  margin-top: 10rpx;
}

.condition-item {
  margin-right: 10rpx;
  margin-bottom: 10rpx;
  padding: 9rpx 12rpx;
  color: #405047;
  font-size: 22rpx;
  line-height: 1.25;
  background: #eef3ec;
  border-radius: 8rpx;
}

.provider {
  display: block;
  margin-top: 6rpx;
  color: #818b85;
  font-size: 22rpx;
  line-height: 1.4;
}

.card-action-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 18rpx;
  padding-top: 18rpx;
  border-top: 1rpx solid #eef2ed;
}

.action-note {
  color: #87918a;
  font-size: 22rpx;
  line-height: 1.3;
}

.signup-button {
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 0 0 auto;
  min-width: 158rpx;
  min-height: 88rpx;
  padding: 12rpx 18rpx;
  box-sizing: border-box;
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 600;
  line-height: 1.3;
  background: #1f7a4d;
  border-radius: 8rpx;
}

.signup-button-limited {
  background: #c86f21;
}

.signup-button-ended {
  color: #55615a;
  background: #e5e9e5;
}

.empty-state {
  padding: 56rpx 28rpx;
  text-align: center;
  background: #ffffff;
  border: 1rpx solid #e7ebe3;
  border-radius: 8rpx;
}

.empty-title {
  display: block;
  color: #26342d;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1.35;
}

.empty-text {
  display: block;
  margin-top: 10rpx;
  color: #7a837d;
  font-size: 25rpx;
  line-height: 1.4;
}
