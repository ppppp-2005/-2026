page {
  background: #f6f4ec;
}

button::after {
  border: 0;
}

.events-page {
  min-height: 100vh;
  padding: 24rpx 24rpx 56rpx;
  color: #17251d;
  background: #f6f4ec;
}

.events-hero {
  min-height: 232rpx;
  padding: 30rpx;
  color: #ffffff;
  background: linear-gradient(135deg, #1f7149 0%, #2e8658 72%, #bd7b38 100%);
  border-radius: 14rpx;
}

.hero-top,
.section-head,
.card-top,
.card-bottom,
.fact-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.hero-label,
.hero-data {
  padding: 7rpx 13rpx;
  font-size: 22rpx;
  line-height: 1.3;
  border-radius: 8rpx;
}

.hero-label {
  color: #fff8df;
  background: rgba(19, 61, 40, 0.36);
}

.hero-data {
  margin-left: 18rpx;
  color: #eff8f1;
  border: 1rpx solid rgba(255, 255, 255, 0.42);
}

.hero-title {
  margin-top: 26rpx;
  font-size: 46rpx;
  font-weight: 700;
  line-height: 1.2;
}

.hero-subtitle {
  margin-top: 12rpx;
  color: rgba(255, 255, 255, 0.9);
  font-size: 26rpx;
  line-height: 1.5;
}

.truth-note {
  display: flex;
  align-items: flex-start;
  margin-top: 18rpx;
  padding: 19rpx 21rpx;
  background: #fff6e5;
  border: 1rpx solid #ead4a8;
  border-radius: 12rpx;
}

.truth-title {
  flex: 0 0 auto;
  color: #8b531b;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 1.5;
}

.truth-copy {
  flex: 1;
  margin-left: 14rpx;
  color: #755b38;
  font-size: 23rpx;
  line-height: 1.5;
}

.type-tabs {
  display: flex;
  margin-top: 20rpx;
  padding: 8rpx;
  background: #ffffff;
  border: 1rpx solid #dfe6dc;
  border-radius: 12rpx;
}

.type-tab {
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 1;
  min-height: 88rpx;
  margin: 0;
  padding: 14rpx 10rpx;
  color: #445149;
  font-size: 27rpx;
  font-weight: 600;
  line-height: 1.35;
  background: transparent;
  border-radius: 9rpx;
}

.type-tab-active {
  color: #ffffff;
  background: #1f7149;
}

.status-scroll {
  width: 100%;
  margin-top: 16rpx;
  white-space: nowrap;
}

.status-row {
  display: inline-flex;
  min-width: 100%;
}

.status-chip {
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 0 0 auto;
  min-height: 88rpx;
  margin: 0 12rpx 0 0;
  padding: 14rpx 24rpx;
  color: #536057;
  font-size: 25rpx;
  line-height: 1.3;
  background: #ffffff;
  border: 1rpx solid #dce4da;
  border-radius: 999rpx;
}

.status-chip-active {
  color: #1f7149;
  font-weight: 700;
  background: #e9f4ed;
  border-color: #b8d6c1;
}

.section-head {
  align-items: flex-end;
  margin: 28rpx 0 16rpx;
}

.section-title,
.section-subtitle {
  display: block;
}

.section-title {
  font-size: 34rpx;
  font-weight: 700;
}

.section-subtitle {
  margin-top: 8rpx;
  color: #748078;
  font-size: 22rpx;
  line-height: 1.45;
}

.result-count {
  flex: 0 0 auto;
  margin-left: 18rpx;
  color: #1f7149;
  font-size: 24rpx;
  font-weight: 700;
}

.event-card,
.state-card {
  background: #ffffff;
  border: 1rpx solid #e1e7de;
  border-radius: 14rpx;
}

.event-card {
  margin-bottom: 18rpx;
  padding: 24rpx;
  box-shadow: 0 8rpx 20rpx rgba(29, 49, 38, 0.04);
}

.type-badge,
.status-badge {
  padding: 6rpx 11rpx;
  font-size: 22rpx;
  line-height: 1.3;
  border-radius: 7rpx;
}

.type-badge {
  color: #1f7149;
  background: #e9f4ed;
}

.status-badge {
  margin-left: 14rpx;
  color: #6a5a3b;
  background: #f2eee5;
}

.status-ongoing {
  color: #ffffff;
  background: #1f7149;
}

.status-upcoming {
  color: #8b531b;
  background: #fff0d7;
}

.status-ended {
  color: #68736c;
  background: #edf0ec;
}

.event-title {
  display: block;
  margin-top: 19rpx;
  color: #17251d;
  font-size: 33rpx;
  font-weight: 700;
  line-height: 1.35;
}

.event-summary {
  display: block;
  margin-top: 10rpx;
  color: #667169;
  font-size: 25rpx;
  line-height: 1.55;
}

.event-facts {
  margin-top: 20rpx;
  padding: 8rpx 18rpx;
  background: #f8faf6;
  border-radius: 10rpx;
}

.fact-row {
  align-items: flex-start;
  padding: 11rpx 0;
  border-bottom: 1rpx solid #e9eee7;
}

.fact-row:last-child {
  border-bottom: 0;
}

.fact-label {
  flex: 0 0 auto;
  width: 128rpx;
  color: #34473b;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 1.5;
}

.fact-value {
  flex: 1;
  min-width: 0;
  color: #637067;
  font-size: 24rpx;
  line-height: 1.5;
}

.card-bottom {
  margin-top: 18rpx;
  padding-top: 18rpx;
  border-top: 1rpx solid #edf1ec;
}

.card-hint {
  color: #758078;
  font-size: 22rpx;
  line-height: 1.4;
}

.detail-action,
.state-action {
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 88rpx;
  padding: 14rpx 24rpx;
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 700;
  line-height: 1.35;
  background: #1f7149;
  border-radius: 10rpx;
}

.detail-action {
  flex: 0 0 auto;
  margin: 0 0 0 16rpx;
}

.state-card {
  display: flex;
  align-items: center;
  flex-direction: column;
  padding: 52rpx 28rpx;
  text-align: center;
}

.state-card-error {
  background: #fff9f4;
  border-color: #ecd4c2;
}

.state-title {
  font-size: 32rpx;
  font-weight: 700;
}

.state-copy {
  margin-top: 12rpx;
  color: #6c776f;
  font-size: 25rpx;
  line-height: 1.5;
}

.state-action {
  margin: 24rpx 0 0;
}

@media (max-width: 340px) {
  .events-page {
    padding-right: 18rpx;
    padding-left: 18rpx;
  }

  .hero-title {
    font-size: 41rpx;
  }

  .truth-note,
  .card-bottom,
  .fact-row {
    flex-direction: column;
  }

  .truth-copy,
  .detail-action {
    margin-top: 10rpx;
    margin-left: 0;
  }

  .fact-label {
    width: auto;
  }

  .fact-value {
    margin-top: 4rpx;
  }

  .card-bottom {
    align-items: stretch;
  }
}
