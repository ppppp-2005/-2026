page {
  min-height: 100%;
  background: #f6f7f2;
  color: #1f2933;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  font-size: 32rpx;
}

view,
text {
  box-sizing: border-box;
}

.page {
  min-height: 100vh;
  padding: 40rpx 32rpx;
}

.page-title {
  font-size: 44rpx;
  font-weight: 700;
  line-height: 1.3;
  color: #16251d;
}

.page-subtitle {
  margin-top: 16rpx;
  color: #6b7280;
  font-size: 28rpx;
  line-height: 1.6;
}

.placeholder-panel {
  margin-top: 36rpx;
  padding: 32rpx;
  background: #ffffff;
  border: 1rpx solid #e5e7eb;
  border-radius: 8rpx;
}

.placeholder-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1f7a4d;
}

.placeholder-text {
  margin-top: 12rpx;
  color: #4b5563;
  font-size: 28rpx;
  line-height: 1.6;
}
